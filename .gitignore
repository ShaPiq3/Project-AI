# Unity .gitignore

```gitignore
# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from:
# https://github.com/github/gitignore/blob/main/Unity.gitignore

############################
# Unity generated folders
############################
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/
UserSettings/

############################
# Addressables
############################
ServerData/

############################
# Asset meta data
############################
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

############################
# Visual Studio / Rider
############################
.vs/
.gradle/
ExportedObj/
.consulo/
.idea/

*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs

############################
# OS generated files
############################
.DS_Store
Thumbs.db
desktop.ini

############################
# Unity auto-generated files
############################
sysinfo.txt

############################
# Crash Reports
############################
crashlytics-build.properties

############################
# Packages
############################
# Keep manifest and lock files
!/[Pp]ackages
/[Pp]ackages/*
!/[Pp]ackages/manifest.json
!/[Pp]ackages/packages-lock.json

############################
# JetBrains Rider
############################
.idea/
*.sln.iml

############################
# VS Code
############################
.vscode/

############################
# Android
############################
*.apk
*.aab

############################
# iOS
############################
*.xcworkspace
*.xcodeproj

############################
# Generated by Unity Collaborate
############################
.collabignore

############################
# Burst cache
############################
[Bb]urstCache/

############################
# Addressables build
############################
Assets/AddressableAssetsData/*/*.bin*

############################
# Streaming Assets generated files
############################
Assets/StreamingAssets/aa.meta
Assets/StreamingAssets/aa/
