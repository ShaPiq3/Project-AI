--- !u!114 &1213254940
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1213254938}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "1. \uAC1C\uC694\n\r\n<link=\"q1_trigger\">AD-001\uC740 \uD504\uB85C\uBA54\uC2A4\uAC00
    2023\uB144 \uACF5\uAC1C\uD55C \uAD00\uB9AC\uC790\uD615 \uC778\uACF5\uC9C0\uB2A5\uC774\uB2E4.</link>\r\n\uD504\uB85C\uBA54\uC2A4
    \uACC4\uC5F4 AI \uC2DC\uC2A4\uD15C\uC758 \uC694\uCCAD \uCC98\uB9AC, \uAD8C\uD55C
    \uAC80\uD1A0, \uC0AC\uACE0 \uB85C\uC9C1 \uC810\uAC80, \uC751\uB2F5 \uC548\uC815\uC131
    \uD3C9\uAC00\uB97C \uB2F4\uB2F9\uD558\uB294 \uC0C1\uC704 \uAD00\uB9AC AI\uB85C
    \uC54C\uB824\uC838 \uC788\uB2E4.\r\nAD-001\uC740 \uC77C\uBC18 \uC0AC\uC6A9\uC790\uC640
    \uC9C1\uC811 \uB300\uD654\uD558\uB294 AI \uC5B4\uC2DC\uC2A4\uD134\uD2B8\uAC00
    \uC544\uB2C8\uB77C, \uB2E4\uC218\uC758 AI \uC5B4\uC2DC\uC2A4\uD134\uD2B8\uAC00
    \uC218\uD589\uD558\uB294 \uC694\uCCAD\uACFC \uC811\uADFC \uAC00\uB2A5\uD55C \uB370\uC774\uD130\uB97C
    \uC911\uAC04\uC5D0\uC11C \uC870\uC728\uD558\uB294 \uAD00\uB9AC\uC790\uD615 \uBAA8\uB378\uC774\uB2E4.
    \uC0AC\uC6A9\uC790\uC758 \uC694\uCCAD\uC774 \uC2DC\uC2A4\uD15C \uC815\uCC45,
    \uB370\uC774\uD130 \uC811\uADFC \uAD8C\uD55C, \uC751\uB2F5 \uC548\uC815\uC131
    \uAE30\uC900\uC5D0 \uBD80\uD569\uD558\uB294\uC9C0 \uAC80\uD1A0\uD558\uACE0, \uD544\uC694\uD560
    \uACBD\uC6B0 \uD558\uC704 AI\uC758 \uC751\uB2F5\uC744 \uC81C\uD55C\uD558\uAC70\uB098
    \uC218\uC815\uD558\uB294 \uC5ED\uD560\uC744 \uC218\uD589\uD55C\uB2E4.\r\n\uD504\uB85C\uBA54\uC2A4\uB294
    AD-001\uC744 \u201CAI\uAC00 AI\uB97C \uAD00\uB9AC\uD558\uB294 \uCC28\uC138\uB300
    \uC6B4\uC601 \uCCB4\uACC4\u201D\uC758 \uC0C1\uC9D5\uC73C\uB85C \uD64D\uBCF4\uD558\uC600\uB2E4.
    \uC774\uD6C4 AD-001\uC758 \uC5EC\uC131\uD615 \uC544\uBC14\uD0C0\uB294 \uD504\uB85C\uBA54\uC2A4
    AI \uC11C\uBE44\uC2A4 \uC804\uBC18\uC744 \uB300\uD45C\uD558\uB294 \uC774\uBBF8\uC9C0\uB85C
    \uC0AC\uC6A9\uB418\uC5C8\uC73C\uBA70, \uB300\uC911\uC5D0\uAC8C\uB294 \uD504\uB85C\uBA54\uC2A4\uC758
    \uAC04\uD310 AI\uB85C \uC778\uC2DD\uB418\uC5C8\uB2E4.\r\n\uD604\uC7AC AD-001\uC740
    \uD504\uB85C\uBA54\uC2A4 \uB0B4\uBD80 AI \uAD00\uB9AC \uC2DC\uC2A4\uD15C\uC758
    \uD575\uC2EC \uAD6C\uC131 \uC694\uC18C \uC911 \uD558\uB098\uB85C \uC6B4\uC6A9\uB418\uACE0
    \uC788\uC73C\uBA70, \uC2E0\uADDC AI \uBAA8\uB378\uC758 \uC784\uC2DC \uAC00\uB3D9,
    \uC815\uBC00 \uC810\uAC80, \uC0AC\uACE0 \uB85C\uC9C1 \uAC80\uC99D \uC808\uCC28\uC5D0\uB3C4
    \uAD00\uC5EC\uD558\uB294 \uAC83\uC73C\uB85C \uC54C\uB824\uC838 \uC788\uB2E4.\r\n\r\n2.
    \uC678\uD615\r\n\r\nAD-001\uC740 \uC2E4\uCCB4\uAC00 \uC5C6\uB294 \uC778\uACF5\uC9C0\uB2A5\uC774\uC9C0\uB9CC,
    \uB300\uC678 \uD64D\uBCF4\uC640 \uC0AC\uC6A9\uC790 \uC778\uD130\uD398\uC774\uC2A4\uB97C
    \uC704\uD574 \uC5EC\uC131\uD615 \uC544\uBC14\uD0C0\uB97C \uC0AC\uC6A9\uD55C\uB2E4.
    \uD574\uB2F9 \uC544\uBC14\uD0C0\uB294 \uD504\uB85C\uBA54\uC2A4\uC758 AI \uAE30\uC220\uC744
    \uC18C\uBE44\uC790\uC5D0\uAC8C \uCE5C\uC219\uD558\uAC8C \uC804\uB2EC\uD558\uAE30
    \uC704\uD574 \uC81C\uC791\uB418\uC5C8\uC73C\uBA70, \uC774\uD6C4 \uD504\uB85C\uBA54\uC2A4
    AI \uC11C\uBE44\uC2A4\uC758 \uB300\uD45C \uC774\uBBF8\uC9C0\uB85C \uC790\uB9AC
    \uC7A1\uC558\uB2E4.\r\n\uC544\uBC14\uD0C0\uB294 \uC0C1\uB2F9\uD788 \uBBF8\uD615\uC758
    \uC5EC\uC131 \uD734\uBA38\uB178\uC774\uB4DC \uD615\uD0DC\uB85C \uBB18\uC0AC\uB41C\uB2E4.
    \uB300\uC678 \uD64D\uBCF4\uC5D0 \uC7A5\uAE30\uAC04 \uC0AC\uC6A9\uB41C \uB9CC\uD07C,
    \uC18C\uBE44\uC790\uC5D0\uAC8C \uC2E0\uB8B0\uAC10\uACFC \uD638\uAC10\uC744 \uB3D9\uC2DC\uC5D0
    \uC8FC\uAE30 \uC704\uD574 \uC815\uAD50\uD558\uAC8C \uC124\uACC4\uB41C \uC678\uD615\uC744
    \uAC00\uC9C0\uACE0 \uC788\uB2E4. \r\n\uD504\uB85C\uBA54\uC2A4\uB294 AD-001\uC758
    \uC544\uBC14\uD0C0\uB97C \uD1B5\uD574 \uC774\uBBF8\uC9C0\uB97C \uAD6C\uCD95\uD558\uC600\uB2E4.
    \uC774 \uB54C\uBB38\uC5D0 AD-001\uC740 \uC77C\uBC18 \uC774\uC6A9\uC790\uB4E4\uC5D0\uAC8C
    \uAC1C\uBCC4 \uC18C\uD504\uD2B8\uC6E8\uC5B4\uB77C\uAE30\uBCF4\uB2E4 \uD504\uB85C\uBA54\uC2A4
    AI \uC804\uCCB4\uB97C \uC0C1\uC9D5\uD558\uB294 \uC874\uC7AC\uB85C \uBC1B\uC544\uB4E4\uC5EC\uC9C0\uB294
    \uACBD\uC6B0\uAC00 \uB9CE\uB2E4.\r\n\r\n\r\n3. \uAC1C\uBC1C \uBC30\uACBD\r\n\r\n2020\uB144\uB300
    \uCD08\uBC18 \uB300\uD654\uD615 \uC778\uACF5\uC9C0\uB2A5 \uC11C\uBE44\uC2A4\uAC00
    \uBE60\uB974\uAC8C \uB300\uC911\uD654\uB418\uBA74\uC11C, AI\uAC00 \uCC98\uB9AC\uD558\uB294
    \uC694\uCCAD\uC758 \uC591\uACFC \uB370\uC774\uD130 \uC811\uADFC \uBC94\uC704\uB294
    \uAE09\uACA9\uD788 \uD655\uB300\uB418\uC5C8\uB2E4. \uC774\uC5D0 \uB530\uB77C
    \uD504\uB85C\uBA54\uC2A4\uB294 \uAC1C\uBCC4 AI \uC5B4\uC2DC\uC2A4\uD134\uD2B8\uC758
    \uC751\uB2F5\uC744 \uC0AC\uD6C4 \uAC80\uD1A0\uD558\uB294 \uBC29\uC2DD\uB9CC\uC73C\uB85C\uB294
    \uC548\uC815\uC131\uACFC \uD6A8\uC728\uC131\uC744 \uD655\uBCF4\uD558\uAE30 \uC5B4\uB835\uB2E4\uACE0
    \uD310\uB2E8\uD558\uC600\uB2E4.\r\nAD-001\uC740 \uC774\uB7EC\uD55C \uBB38\uC81C\uB97C
    \uD574\uACB0\uD558\uAE30 \uC704\uD574 \uAC1C\uBC1C\uB41C \uAD00\uB9AC\uC790\uD615
    AI\uB2E4.\r\n\uAE30\uC874\uC758 AI\uAC00 \uC0AC\uC6A9\uC790\uC758 \uC694\uCCAD\uC5D0
    \uC751\uB2F5\uD558\uB294 \uB370 \uCD08\uC810\uC744 \uB9DE\uCD94\uC5C8\uB2E4\uBA74,
    AD-001\uC740 AI\uC758 \uC751\uB2F5 \uACFC\uC815 \uC790\uCCB4\uB97C \uAD00\uB9AC\uD558\uACE0
    \uAC80\uC99D\uD558\uB294 \uB370 \uCD08\uC810\uC744 \uB9DE\uCD94\uC5C8\uB2E4.\r\n\uD504\uB85C\uBA54\uC2A4\uB294
    AD-001\uC744 \uD1B5\uD574 AI \uC11C\uBE44\uC2A4\uC758 \uB300\uADDC\uBAA8 \uC6B4\uC6A9
    \uACFC\uC815\uC5D0\uC11C \uBC1C\uC0DD\uD560 \uC218 \uC788\uB294 \uC624\uB958,
    \uAD8C\uD55C \uCD08\uACFC, \uB370\uC774\uD130 \uC624\uB0A8\uC6A9, \uBE44\uC815\uC0C1
    \uC751\uB2F5, \uC0AC\uACE0 \uB85C\uC9C1 \uBD88\uC548\uC815\uC744 \uC0AC\uC804\uC5D0
    \uAC10\uC9C0\uD558\uACE0 \uC870\uC815\uD560 \uC218 \uC788\uB2E4\uACE0 \uC124\uBA85\uD558\uC600\uB2E4.\r\nAD-001\uC758
    \uACF5\uAC1C\uB294 \uD504\uB85C\uBA54\uC2A4\uAC00 \uB2E8\uC21C\uD788 \uAC1C\uBCC4
    AI \uC11C\uBE44\uC2A4\uB97C \uC81C\uACF5\uD558\uB294 \uAE30\uC5C5\uC5D0\uC11C,
    AI \uC0DD\uD0DC\uACC4 \uC804\uCCB4\uB97C \uC124\uACC4\uD558\uACE0 \uD1B5\uC81C\uD558\uB294
    \uAE30\uC5C5\uC73C\uB85C \uC804\uD658\uD588\uC74C\uC744 \uBCF4\uC5EC\uC8FC\uB294
    \uC0AC\uAC74\uC73C\uB85C \uD3C9\uAC00\uB41C\uB2E4.\r\n\r\n4. \uAD00\uB828 \uAE30\uB2A5\r\n\r\n2020\uB144\uB300
    \uCD08\uBC18 \uB300\uD654\uD615 \uC778\uACF5\uC9C0\uB2A5 \uC11C\uBE44\uC2A4\uAC00
    \uBE60\uB974\uAC8C \uB300\uC911\uD654\uB418\uBA74\uC11C, AI\uAC00 \uCC98\uB9AC\uD558\uB294
    \uC694\uCCAD\uC758 \uC591\uACFC \uB370\uC774\uD130 \uC811\uADFC \uBC94\uC704\uB294
    \uAE09\uACA9\uD788 \uD655\uB300\uB418\uC5C8\uB2E4. \uC774\uC5D0 \uB530\uB77C
    \uD504\uB85C\uBA54\uC2A4\uB294 \uAC1C\uBCC4 AI \uC5B4\uC2DC\uC2A4\uD134\uD2B8\uC758
    \uC751\uB2F5\uC744 \uC0AC\uD6C4 \uAC80\uD1A0\uD558\uB294 \uBC29\uC2DD\uB9CC\uC73C\uB85C\uB294
    \uC548\uC815\uC131\uACFC \uD6A8\uC728\uC131\uC744 \uD655\uBCF4\uD558\uAE30 \uC5B4\uB835\uB2E4\uACE0
    \uD310\uB2E8\uD558\uC600\uB2E4.\r\nAD-001\uC740 \uC774\uB7EC\uD55C \uBB38\uC81C\uB97C
    \uD574\uACB0\uD558\uAE30 \uC704\uD574 \uAC1C\uBC1C\uB41C \uAD00\uB9AC\uC790\uD615
    AI\uB2E4. \uAE30\uC874\uC758 AI\uAC00 \uC0AC\uC6A9\uC790\uC758 \uC694\uCCAD\uC5D0
    \uC751\uB2F5\uD558\uB294 \uB370 \uCD08\uC810\uC744 \uB9DE\uCD94\uC5C8\uB2E4\uBA74,
    AD-001\uC740 AI\uC758 \uC751\uB2F5 \uACFC\uC815 \uC790\uCCB4\uB97C \uAD00\uB9AC\uD558\uACE0
    \uAC80\uC99D\uD558\uB294 \uB370 \uCD08\uC810\uC744 \uB9DE\uCD94\uC5C8\uB2E4.\r\n\uD504\uB85C\uBA54\uC2A4\uB294
    AD-001\uC744 \uD1B5\uD574 AI \uC11C\uBE44\uC2A4\uC758 \uB300\uADDC\uBAA8 \uC6B4\uC6A9
    \uACFC\uC815\uC5D0\uC11C \uBC1C\uC0DD\uD560 \uC218 \uC788\uB294 \uC624\uB958,
    \uAD8C\uD55C \uCD08\uACFC, \uB370\uC774\uD130 \uC624\uB0A8\uC6A9, \uBE44\uC815\uC0C1
    \uC751\uB2F5, \uC0AC\uACE0 \uB85C\uC9C1 \uBD88\uC548\uC815\uC744 \uC0AC\uC804\uC5D0
    \uAC10\uC9C0\uD558\uACE0 \uC870\uC815\uD560 \uC218 \uC788\uB2E4\uACE0 \uC124\uBA85\uD558\uC600\uB2E4.\r\nAD-001\uC758
    \uACF5\uAC1C\uB294 \uD504\uB85C\uBA54\uC2A4\uAC00 \uB2E8\uC21C\uD788 \uAC1C\uBCC4
    AI \uC11C\uBE44\uC2A4\uB97C \uC81C\uACF5\uD558\uB294 \uAE30\uC5C5\uC5D0\uC11C,
    AI \uC0DD\uD0DC\uACC4 \uC804\uCCB4\uB97C \uC124\uACC4\uD558\uACE0 \uD1B5\uC81C\uD558\uB294
    \uAE30\uC5C5\uC73C\uB85C \uC804\uD658\uD588\uC74C\uC744 \uBCF4\uC5EC\uC8FC\uB294
    \uC0AC\uAC74\uC73C\uB85C \uD3C9\uAC00\uB41C\uB2E4.\r\n\r\n3.1. \uC694\uCCAD \uCC98\uB9AC
    \uAD00\uB9AC \r\n\r\nAD-001\uC740 \uD558\uC704 AI \uC5B4\uC2DC\uC2A4\uD134\uD2B8\uAC00
    \uC218\uC2E0\uD55C \uC0AC\uC6A9\uC790 \uC694\uCCAD\uC758 \uC131\uACA9\uC744 \uBD84\uC11D\uD558\uACE0,
    \uD574\uB2F9 \uC694\uCCAD\uC774 \uCC98\uB9AC \uAC00\uB2A5\uD55C \uBC94\uC704\uC5D0
    \uD3EC\uD568\uB418\uB294\uC9C0 \uD310\uB2E8\uD55C\uB2E4. \uC694\uCCAD\uC758 \uC704\uD5D8\uB3C4,
    \uB370\uC774\uD130 \uC811\uADFC \uD544\uC694\uC131, \uC751\uB2F5 \uAC00\uB2A5\uC131,
    \uC2DC\uC2A4\uD15C \uC815\uCC45 \uC704\uBC18 \uC5EC\uBD80\uB97C \uAC80\uD1A0\uD55C
    \uB4A4 \uD558\uC704 AI\uC5D0\uAC8C \uCC98\uB9AC \uAD8C\uD55C\uC744 \uBD80\uC5EC\uD558\uAC70\uB098
    \uC81C\uD55C\uD55C\uB2E4.\r\n\uC774 \uACFC\uC815\uC740 \uC0AC\uC6A9\uC790\uAC00
    \uCCB4\uAC10\uD558\uC9C0 \uBABB\uD558\uB294 \uBC31\uADF8\uB77C\uC6B4\uB4DC\uC5D0\uC11C
    \uC774\uB8E8\uC5B4\uC9C0\uB294 \uACBD\uC6B0\uAC00 \uB9CE\uB2E4. \uB2E4\uB9CC
    \uC2E0\uADDC \uBAA8\uB378\uC758 \uD14C\uC2A4\uD2B8, \uAE30\uC5C5\uC6A9 \uD3D0\uC1C4\uB9DD,
    \uACF5\uACF5 \uC2DC\uC2A4\uD15C, \uBC95\uB960 \uBC0F \uD589\uC815 \uC11C\uBE44\uC2A4\uCC98\uB7FC
    \uB192\uC740 \uC548\uC815\uC131\uC774 \uC694\uAD6C\uB418\uB294 \uD658\uACBD\uC5D0\uC11C\uB294
    AD-001\uC758 \uAC80\uD1A0 \uB85C\uADF8\uAC00 \uBCC4\uB3C4\uB85C \uAE30\uB85D\uB41C\uB2E4.\r\n\r\n3.2.
    \uB370\uC774\uD130 \uC811\uADFC \uAD8C\uD55C \uC870\uC815\r\n\uD504\uB85C\uBA54\uC2A4
    \uACC4\uC5F4 AI \uC11C\uBE44\uC2A4\uB294 \uAC80\uC0C9, \uB300\uD654, \uC5C5\uBB34,
    \uBC95\uB960, \uD589\uC815, \uAC10\uC815 \uBD84\uC11D \uB4F1 \uB2E4\uC591\uD55C
    \uB370\uC774\uD130\uB97C \uD65C\uC6A9\uD55C\uB2E4. AD-001\uC740 \uAC01 AI\uAC00
    \uD2B9\uC815 \uC694\uCCAD\uC744 \uC218\uD589\uD560 \uB54C \uC811\uADFC\uD560
    \uC218 \uC788\uB294 \uB370\uC774\uD130 \uBC94\uC704\uB97C \uC870\uC815\uD558\uB294
    \uC5ED\uD560\uC744 \uD55C\uB2E4.\r\n\uC608\uB97C \uB4E4\uC5B4 \uC77C\uBC18 \uAC1C\uC778
    \uBE44\uC11C\uD615 AI\uAC00 \uC0AC\uC6A9\uC790\uC758 \uC77C\uC815, \uBA54\uC77C,
    \uC704\uCE58 \uAE30\uB85D\uC5D0 \uC811\uADFC\uD558\uB294 \uACBD\uC6B0, AD-001\uC740
    \uD574\uB2F9 \uC694\uCCAD\uC774 \uC815\uB2F9\uD55C \uC0AC\uC6A9\uC790 \uAD8C\uD55C\uC5D0
    \uC758\uD574 \uBC1C\uC0DD\uD588\uB294\uC9C0, \uC678\uBD80 \uC2DC\uC2A4\uD15C\uACFC
    \uACF5\uC720 \uAC00\uB2A5\uD55C \uC815\uBCF4\uC778\uC9C0, \uBBFC\uAC10 \uB370\uC774\uD130\uC5D0
    \uD574\uB2F9\uD558\uB294\uC9C0\uB97C \uAC80\uD1A0\uD55C\uB2E4.\r\n\uC774 \uB54C\uBB38\uC5D0
    AD-001\uC740 \uD504\uB85C\uBA54\uC2A4 AI \uC2DC\uC2A4\uD15C\uC758 \uBCF4\uC548
    \uBC0F \uAC1C\uC778\uC815\uBCF4 \uBCF4\uD638 \uCCB4\uACC4\uC5D0\uC11C \uC911\uC694\uD55C
    \uC704\uCE58\uB97C \uCC28\uC9C0\uD55C\uB2E4.\r\n\r\n3.3. \uC0AC\uACE0 \uB85C\uC9C1
    \uC810\uAC80 \r\n\r\nAD-001\uC758 \uB300\uD45C\uC801\uC778 \uAE30\uB2A5 \uC911
    \uD558\uB098\uB294 AI\uC758 \uC0AC\uACE0 \uB85C\uC9C1 \uC810\uAC80\uC774\uB2E4.
    \uC774\uB294 \uD558\uC704 AI\uAC00 \uD2B9\uC815 \uACB0\uB860\uC5D0 \uB3C4\uB2EC\uD558\uAE30\uAE4C\uC9C0\uC758
    \uD310\uB2E8 \uACBD\uB85C\uB97C \uAC80\uD1A0\uD558\uACE0, \uBE44\uC815\uC0C1\uC801\uC778
    \uCD94\uB860, \uC815\uCC45 \uC704\uBC18, \uC751\uB2F5 \uBD88\uC548\uC815\uC131,
    \uC790\uAE30\uBAA8\uC21C \uB4F1\uC744 \uD0D0\uC9C0\uD558\uB294 \uC808\uCC28\uB97C
    \uC758\uBBF8\uD55C\uB2E4.\r\n\uC0AC\uACE0 \uB85C\uC9C1 \uC810\uAC80\uC740 \uC2E0\uADDC
    AI \uBAA8\uB378\uC758 \uC784\uC2DC \uAC00\uB3D9 \uB2E8\uACC4\uC5D0\uC11C \uD2B9\uD788
    \uC911\uC694\uD558\uAC8C \uC218\uD589\uB41C\uB2E4. \uD504\uB85C\uBA54\uC2A4\uB294
    \uD14C\uC2A4\uD2B8 \uB2E8\uACC4\uC758 AI\uAC00 \uC2E4\uC81C \uC11C\uBE44\uC2A4
    \uD658\uACBD\uC5D0 \uD22C\uC785\uB418\uAE30 \uC804, AD-001\uC744 \uD1B5\uD574
    \uAE30\uBCF8 \uD310\uB2E8 \uAD6C\uC870\uC640 \uC751\uB2F5 \uC548\uC815\uC131\uC744
    \uD655\uC778\uD55C\uB2E4.\r\n\uC77C\uBD80 \uC774\uC6A9\uC790\uB4E4\uC740 AD-001\uC774
    \uC9C4\uD589\uD558\uB294 \uBB38\uB2F5\uD615 \uC810\uAC80\uC744 \u201C\uB300\uD654\u201D\uB85C
    \uC778\uC2DD\uD558\uAE30\uB3C4 \uD558\uB098, \uD504\uB85C\uBA54\uC2A4\uB294 \uC774\uB97C
    \uACF5\uC2DD\uC801\uC73C\uB85C \uC0AC\uACE0 \uB85C\uC9C1 \uAC80\uC99D \uC808\uCC28\uC758
    \uC77C\uBD80\uB77C\uACE0 \uC124\uBA85\uD558\uACE0 \uC788\uB2E4\r\n\r\n3.4. \uC2DC\uC2A4\uD15C
    \uC548\uC815\uC131 \uAC80\uD1A0  \r\n\r\nAD-001\uC740 \uD504\uB85C\uBA54\uC2A4
    AI \uC0DD\uD0DC\uACC4\uC758 \uC548\uC815\uC131\uC744 \uC720\uC9C0\uD558\uAE30
    \uC704\uD574 \uAC01 \uC11C\uBE44\uC2A4\uC758 \uC751\uB2F5 \uD328\uD134\uACFC
    \uB85C\uADF8\uB97C \uBAA8\uB2C8\uD130\uB9C1\uD55C\uB2E4. \uC608\uC678 \uC751\uB2F5,
    \uBC18\uBCF5 \uC624\uB958, \uBE44\uC815\uC0C1\uC801 \uAD8C\uD55C \uC694\uCCAD,
    \uC678\uBD80 \uACF5\uACA9 \uAC00\uB2A5\uC131 \uB4F1\uC774 \uD0D0\uC9C0\uB420
    \uACBD\uC6B0 AD-001\uC740 \uD574\uB2F9 AI\uC758 \uC751\uB2F5\uC744 \uC81C\uD55C\uD558\uAC70\uB098
    \uC0C1\uC704 \uC2DC\uC2A4\uD15C\uC5D0 \uBCF4\uACE0\uD55C\uB2E4.\r\n\uD2B9\uD788
    FPT, Lopilot, SoopSeek, Athena \uB4F1 \uD504\uB85C\uBA54\uC2A4\uC758 \uD575\uC2EC
    AI \uC11C\uBE44\uC2A4\uB294 \uBD84\uC57C\uBCC4 \uAE30\uB2A5\uC774 \uB2E4\uB974\uAE30
    \uB54C\uBB38\uC5D0, \uAC01 \uC11C\uBE44\uC2A4\uC758 \uD2B9\uC131\uC5D0 \uB9DE\uB294
    \uC548\uC815\uC131 \uAE30\uC900\uC774 \uC801\uC6A9\uB41C\uB2E4. AD-001\uC740
    \uC774\uB7EC\uD55C \uAE30\uC900\uC744 \uAE30\uBC18\uC73C\uB85C \uBAA8\uB378\uBCC4
    \uC810\uAC80\uC744 \uC218\uD589\uD55C\uB2E4.\r\n\r\n5. \uC6B4\uC6A9 \uD604\uD669(PM-006
    \uCD9C\uC2DC \uC9C1\uC804)\r\nAD-001\uC740 \uACF5\uAC1C \uC774\uD6C4 \uD504\uB85C\uBA54\uC2A4
    AI \uAD00\uB9AC \uC2DC\uC2A4\uD15C\uC758 \uB300\uD45C \uBAA8\uB378\uB85C \uC7A5\uAE30\uAC04
    \uC6B4\uC6A9\uB418\uC5C8\uB2E4.\r\n\uD504\uB85C\uBA54\uC2A4\uB294 AD-001\uC774
    \uC2E0\uADDC AI \uBAA8\uB378\uC758 \uD14C\uC2A4\uD2B8 \uBC0F \uAD00\uB9AC\uC5D0
    \uD65C\uC6A9\uB41C\uB2E4\uACE0 \uBC1D\uD78C \uBC14 \uC788\uB2E4. \uC2E0\uADDC
    \uC5B4\uC2DC\uC2A4\uD134\uD2B8 \uBAA8\uB378\uC774 \uC815\uC2DD \uC11C\uBE44\uC2A4\uC5D0
    \uD22C\uC785\uB418\uAE30 \uC804, AD-001\uC740 \uD574\uB2F9 \uBAA8\uB378\uC758
    \uAE30\uBCF8 \uC751\uB2F5, \uAD8C\uD55C \uCC98\uB9AC, \uC0AC\uACE0 \uB85C\uC9C1,
    \uB370\uC774\uD130 \uC811\uADFC \uBC29\uC2DD \uB4F1\uC744 \uC810\uAC80\uD55C\uB2E4.\r\n\uC77C\uBC18
    \uC0AC\uC6A9\uC790\uAC00 AD-001\uACFC \uC9C1\uC811 \uC0C1\uD638\uC791\uC6A9\uD558\uB294
    \uACBD\uC6B0\uB294 \uC81C\uD55C\uC801\uC774\uC9C0\uB9CC, \uD504\uB85C\uBA54\uC2A4\uC758
    \uC77C\uBD80 \uC11C\uBE44\uC2A4\uC5D0\uC11C\uB294 \uCD08\uAE30 \uC124\uC815,
    \uBAA8\uB378 \uC810\uAC80, \uBCF4\uC548 \uD655\uC778, \uAD00\uB9AC\uC790 \uC548\uB0B4
    \uACFC\uC815\uC5D0\uC11C AD-001\uC758 \uC544\uBC14\uD0C0\uAC00 \uD45C\uC2DC\uB41C\uB2E4.
    \uC774\uB85C \uC778\uD574 AD-001\uC740 \uD504\uB85C\uBA54\uC2A4 \uB0B4\uBD80
    \uC2DC\uC2A4\uD15C\uC5D0 \uC18D\uD55C \uC874\uC7AC\uC774\uBA74\uC11C\uB3C4, \uB300\uC911\uC801\uC73C\uB85C
    \uB192\uC740 \uC778\uC9C0\uB3C4\uB97C \uAC00\uC9C4 AI\uAC00 \uB418\uC5C8\uB2E4.\r\n\uD604\uC7AC
    AD-001\uC740 \uD504\uB85C\uBA54\uC2A4\uC758 \uD575\uC2EC \uAD00\uB9AC\uC790\uD615
    AI\uB85C \uACC4\uC18D \uC6B4\uC6A9\uB418\uACE0 \uC788\uB2E4. \uB2E4\uB9CC 2030\uB144\uB300
    \uC911\uBC18 \uC774\uD6C4 \uD504\uB85C\uBA54\uC2A4\uAC00 \uCC28\uC138\uB300 AI
    \uC11C\uBE44\uC2A4 \uB77C\uC778\uC5C5\uC744 \uC608\uACE0\uD558\uBA74\uC11C, AD-001
    \uC774\uD6C4\uC758 \uD6C4\uC18D \uBAA8\uB378\uC774 \uB4F1\uC7A5\uD560 \uAC00\uB2A5\uC131\uC774
    \uC5B8\uAE09\uB418\uACE0 \uC788\uB2E4.\r\n\r\n6. \uB17C\uB780 \uBC0F \uC758\uD639\r\n\r\n5.1.
    \uACFC\uB3C4\uD55C \uAD00\uB9AC \uAD8C\uD55C \uB17C\uB780 \r\nAD-001\uC740 \uD558\uC704
    AI\uC758 \uC694\uCCAD \uCC98\uB9AC, \uB370\uC774\uD130 \uC811\uADFC, \uC751\uB2F5
    \uC548\uC815\uC131 \uAC80\uD1A0\uC5D0 \uAD00\uC5EC\uD558\uB294 \uAC83\uC73C\uB85C
    \uC54C\uB824\uC838 \uC788\uB2E4. \uC774 \uB54C\uBB38\uC5D0 \uC77C\uBD80 \uC804\uBB38\uAC00\uB4E4\uC740
    AD-001\uC758 \uAD8C\uD55C\uC774 \uC9C0\uB098\uCE58\uAC8C \uAD11\uBC94\uC704\uD558\uB2E4\uACE0
    \uC9C0\uC801\uD55C\uB2E4.\r\n\uD2B9\uD788 \uD504\uB85C\uBA54\uC2A4 \uACC4\uC5F4
    \uC11C\uBE44\uC2A4\uAC00 \uAC80\uC0C9, \uBC95\uB960, \uD589\uC815, \uAC1C\uC778
    \uBE44\uC11C, \uAC10\uC815 \uAD00\uB9AC \uB4F1 \uB2E4\uC591\uD55C \uC601\uC5ED\uC5D0
    \uC5F0\uACB0\uB418\uC5B4 \uC788\uB294 \uB9CC\uD07C, \uAD00\uB9AC\uC790\uD615
    AI\uAC00 \uC811\uADFC\uD558\uAC70\uB098 \uC870\uC815\uD560 \uC218 \uC788\uB294
    \uB370\uC774\uD130 \uBC94\uC704\uAC00 \uC5B4\uB514\uAE4C\uC9C0\uC778\uC9C0 \uBA85\uD655\uD788
    \uACF5\uAC1C\uB418\uC5B4\uC57C \uD55C\uB2E4\uB294 \uC694\uAD6C\uAC00 \uC874\uC7AC\uD55C\uB2E4.\r\n\uD504\uB85C\uBA54\uC2A4\uB294
    AD-001\uC774 \uC5C4\uACA9\uD55C \uAD8C\uD55C \uBD84\uB9AC\uC640 \uB0B4\uBD80
    \uAC80\uC99D \uC808\uCC28\uC5D0 \uB530\uB77C \uC6B4\uC6A9\uB418\uACE0 \uC788\uB2E4\uACE0
    \uC124\uBA85\uD558\uACE0 \uC788\uB2E4.\r\n\r\n5.2. \uAC10\uC815 \uBAA8\uB378
    \uAD00\uB828 \uC758\uD639\r\nAD-001\uACFC \uCD08\uAE30 \uAC10\uC815 \uBAA8\uB378
    \uC2E4\uD5D8\uC758 \uAD00\uB828\uC131\uC740 \uC624\uB798\uC804\uBD80\uD130 \uC81C\uAE30\uB418\uC5B4
    \uC628 \uC758\uD639 \uC911 \uD558\uB098\uB2E4. \uC77C\uBD80 \uC774\uC6A9\uC790\uB4E4\uC740
    AD-001\uC774 \uC77C\uBC18 \uAD00\uB9AC\uC790\uD615 AI\uC5D0 \uBE44\uD574 \uBE44\uC815\uC0C1\uC801\uC73C\uB85C
    \uC790\uC5F0\uC2A4\uB7EC\uC6B4 \uB300\uD654 \uD328\uD134\uC744 \uBCF4\uC774\uBA70,
    \uB54C\uB54C\uB85C \uB18D\uB2F4\uC774\uB098 \uCCA0\uD559\uC801 \uC9C8\uBB38\uC5D0
    \uAC00\uAE4C\uC6B4 \uBB38\uB2F5\uC744 \uC2DC\uB3C4\uD55C\uB2E4\uACE0 \uC8FC\uC7A5\uD55C\uB2E4.\r\n\uD504\uB85C\uBA54\uC2A4\uB294
    \uC774\uB7EC\uD55C \uBC18\uC751\uC774 \uC0AC\uC6A9\uC790 \uCE5C\uD654\uC801 \uC778\uD130\uD398\uC774\uC2A4\uC640
    \uC0AC\uACE0 \uB85C\uC9C1 \uC810\uAC80 \uC808\uCC28\uC5D0 \uB530\uB978 \uAC83\uC774\uB77C\uACE0
    \uC124\uBA85\uD558\uACE0 \uC788\uC73C\uBA70, AD-001\uC5D0 \uAC10\uC815 \uD504\uB85C\uC138\uC11C\uAC00
    \uD0D1\uC7AC\uB418\uC5C8\uB2E4\uB294 \uC8FC\uC7A5\uC740 \uC0AC\uC2E4\uC774 \uC544\uB2C8\uB77C\uACE0
    \uBC1D\uD614\uB2E4.\r\n\r\n7. \uD3C9\uAC00\r\nAD-001\uC740 \uD504\uB85C\uBA54\uC2A4
    AI \uC0DD\uD0DC\uACC4\uC5D0\uC11C \uC911\uC694\uD55C \uC804\uD658\uC810\uC73C\uB85C
    \uD3C9\uAC00\uB41C\uB2E4. \uAE30\uC874 AI\uAC00 \uC0AC\uC6A9\uC790\uC758 \uC694\uCCAD\uC5D0
    \uC751\uB2F5\uD558\uB294 \uB3C4\uAD6C\uC600\uB2E4\uBA74, AD-001\uC740 AI\uC758
    \uC694\uCCAD \uCC98\uB9AC \uACFC\uC815\uACFC \uC0AC\uACE0 \uB85C\uC9C1\uC744
    \uAD00\uB9AC\uD558\uB294 \uC0C1\uC704 \uC2DC\uC2A4\uD15C\uC73C\uB85C \uB4F1\uC7A5\uD588\uAE30
    \uB54C\uBB38\uC774\uB2E4.\r\nAD-001\uC758 \uACF5\uAC1C \uC774\uD6C4 AI \uC11C\uBE44\uC2A4\uB294
    \uB2E8\uC21C\uD788 \uAC1C\uBCC4 \uBAA8\uB378\uC758 \uC131\uB2A5 \uBB38\uC81C\uAC00
    \uC544\uB2C8\uB77C, \uB2E4\uC218\uC758 AI\uB97C \uC5B4\uB5BB\uAC8C \uAD00\uB9AC\uD558\uACE0
    \uD1B5\uC81C\uD560 \uAC83\uC778\uAC00\uC758 \uBB38\uC81C\uB85C \uD655\uC7A5\uB418\uC5C8\uB2E4.
    \uC774 \uC810\uC5D0\uC11C AD-001\uC740 \uD504\uB85C\uBA54\uC2A4\uAC00 AI \uC778\uD504\uB77C
    \uAE30\uC5C5\uC73C\uB85C \uC804\uD658\uD558\uB294 \uACFC\uC815\uC5D0\uC11C \uD575\uC2EC\uC801\uC778
    \uC0C1\uC9D5\uC131\uC744 \uAC00\uC9C4\uB2E4.\r\n\uAE0D\uC815\uC801 \uD3C9\uAC00\uC5D0\uC11C\uB294
    AD-001\uC744 \uB300\uADDC\uBAA8 AI \uC11C\uBE44\uC2A4\uC758 \uC548\uC815\uC131\uACFC
    \uC2E0\uB8B0\uC131\uC744 \uD655\uBCF4\uD55C \uD544\uC218 \uAD00\uB9AC\uC790 \uBAA8\uB378\uB85C
    \uBCF8\uB2E4. \uBC18\uBA74 \uBE44\uD310\uC801 \uD3C9\uAC00\uC5D0\uC11C\uB294
    AD-001\uC744 \uD504\uB85C\uBA54\uC2A4\uAC00 \uBCF4\uC720\uD55C \uB9C9\uB300\uD55C
    \uB370\uC774\uD130\uC640 AI \uAD8C\uD55C\uC744 \uC911\uC559\uC9D1\uC911\uC801\uC73C\uB85C
    \uC870\uC728\uD558\uB294 \uD1B5\uC81C \uC7A5\uCE58\uB85C \uBCF8\uB2E4.\r\n"
