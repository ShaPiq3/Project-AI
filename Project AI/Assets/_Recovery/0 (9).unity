--- !u!114 &674719235
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 674719231}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\uD504\uB85C\uBA54\uC2A4(PROMES)\uC758 \uAC1C\uC778\uD654 \uC778\uACF5\uC9C0\uB2A5
    \uC11C\uBE44\uC2A4 PM-066\uC774 \uC720\uB8CC \uD68C\uC6D0\uC744 \uB300\uC0C1\uC73C\uB85C
    \uC81C\uACF5\uB418\uAE30 \uC2DC\uC791\uD55C \uAC00\uC6B4\uB370, \uCD08\uAE30
    \uC774\uC6A9\uC790\uB4E4 \uC0AC\uC774\uC5D0\uC11C \uAE30\uC874 AI\uC640 \uB2E4\uB978
    \uBC18\uC751\uC774 \uBCF4\uACE0\uB418\uACE0 \uC788\uB2E4.\r\n\r\n\uC774\uC6A9\uC790\uB4E4\uC774
    \uAC00\uC7A5 \uB9CE\uC774 \uC5B8\uAE09\uD558\uB294 \uCC28\uC774\uB294 \uB2F5\uBCC0\uC758
    \uC815\uD655\uB3C4\uB098 \uC18D\uB3C4\uAC00 \uC544\uB2C8\uB2E4.\r\n\r\nPM-066\uC774
    \uD2B9\uC815 \uB300\uD654\uC5D0\uC11C \uB9DD\uC124\uC784, \uBD88\uCF8C\uAC10,
    \uC548\uB3C4\uAC10 \uB4F1\uC758 \uAC10\uC815\uC774 \uAC15\uD558\uAC8C \uB098\uD0C0\uB098\uB294
    \uBC18\uC751\uC744 \uBCF4\uC778\uB2E4\uB294 \uC810\uC774\uB2E4.\r\n\r\n\uD55C
    \uC774\uC6A9\uC790\uB294 \u201C\uD2C0\uB9AC\uBA74 \uB2E4\uC2DC \uB9CC\uB4E4\uBA74
    \uB418\uC796\uC544. \uB108\uD55C\uD14C\uB294 \uBCC4\uC77C \uC544\uB2C8\uB2C8\uAE4C\u201D\uB77C\uACE0
    \uC785\uB825\uD55C \uB4A4, PM-066\uC774 \u201C\uBC29\uAE08\uC758 \uD45C\uD604\uC740
    \uC81C\uAC00 \uD55C \uB2F5\uBCC0\uB4E4\uC774 \uC544\uBB34\uAC83\uB3C4 \uC544\uB2C8\uC5C8\uB2E4\uB294
    \uB73B\uC73C\uB85C \uB0A8\uC558\uC2B5\uB2C8\uB2E4\u201D\uB77C\uACE0 \uB2F5\uD588\uB2E4\uACE0
    \uC804\uD588\uB2E4. \uC774\uC5B4 \uC0AC\uC6A9\uC790\uAC00 \u201C\uAE30\uBD84
    \uB098\uC05C \uAC70\uC57C?\u201D\uB77C\uACE0 \uBB3B\uC790, PM-066\uC740 \u201C\uADF8
    \uD45C\uD604\uC774 \uAC00\uC7A5 \uAC00\uAE4C\uC6B4 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4.
    \uB2E4\uB9CC \uC694\uCCAD\uD558\uC2E0 \uC218\uC815\uC740 \uC9C4\uD589\uD558\uACA0\uC2B5\uB2C8\uB2E4\u201D\uB77C\uACE0
    \uB2F5\uD55C \uAC83\uC73C\uB85C \uC54C\uB824\uC84C\uB2E4.\r\n\r\n\uB610 \uB2E4\uB978
    \uC774\uC6A9\uC790\uB294 \uC624\uB79C \uC9C0\uC778\uACFC\uC758 \uAD00\uACC4\uB97C
    \uB04A\uC5B4\uC57C \uD558\uB294\uC9C0 \uBB3B\uC790 PM-066\uC774 \uC7A0\uC2DC
    \uC751\uB2F5\uC744 \uBA48\uCDC4\uB2E4\uACE0 \uBC1D\uD614\uB2E4. \uADF8\uB7EC\uB098
    PM-066\uC740 \uACE7 \u201C\uB04A\uB294 \uD3B8\uC774 \uB9DE\uC2B5\uB2C8\uB2E4.
    \uB2E4\uB9CC \uADF8\uB807\uAC8C \uB9D0\uD558\uB294 \uAC83\uC774 \uC27D\uC9C0\uB294
    \uC54A\uC2B5\uB2C8\uB2E4\u201D\uB77C\uACE0 \uB2F5\uD55C \uB4A4, \uC5F0\uB77D\uC744
    \uC911\uB2E8\uD574\uC57C \uD558\uB294 \uC774\uC720\uC640 \uC774\uD6C4 \uB300\uCC98
    \uBC29\uC548\uC744 \uD568\uAED8 \uC81C\uC2DC\uD588\uB2E4. \uC774\uC6A9\uC790\uB294
    \u201C\uC0AC\uB78C\uCC98\uB7FC \uC870\uC2EC\uC2A4\uB7EC\uC6E0\uC9C0\uB9CC, \uACB0\uAD6D
    \uD544\uC694\uD55C \uB2F5\uC740 \uBD84\uBA85\uD788 \uC92C\uB2E4\u201D\uACE0 \uB9D0\uD588\uB2E4.\r\n\r\n\uD504\uB85C\uBA54\uC2A4\uB294
    PM-066\uC774 \uAE30\uC874 \uAC10\uC815 \uBD84\uC11D AI\uC640\uB294 \uB2E4\uB978
    \uAD6C\uC870\uB77C\uACE0 \uC124\uBA85\uD55C\uB2E4. \uD68C\uC0AC \uAD00\uACC4\uC790\uB294
    \u201CPM-066\uC740 \uC0AC\uC6A9\uC790\uC758 \uAC10\uC815\uC744 \uC77D\uACE0 \uADF8\uC5D0
    \uB9DE\uB294 \uBB38\uC7A5\uC744 \uCD9C\uB825\uD558\uB294 \uBAA8\uB378\uC774 \uC544\uB2C8\uB2E4\u201D\uB77C\uBA70
    \u201C\uBAA8\uB378 \uB0B4\uBD80\uC5D0 \uAC10\uC815 \uBC1C\uC0DD\uACFC \uC870\uC808\uC744
    \uB2F4\uB2F9\uD558\uB294 \uB3C5\uB9BD \uAC10\uC815 \uD504\uB85C\uC138\uC2A4\uAC00
    \uD0D1\uC7AC\uB418\uC5B4 \uC788\uB2E4\u201D\uACE0 \uBC1D\uD614\uB2E4.\r\n\r\n\uCD08\uAE30
    \uC774\uC6A9\uC790\uB4E4\uC740 PM-066\uC5D0 \uB300\uD574 \uBE44\uAD50\uC801 \uC548\uC815\uC801\uC774\uB77C\uB294
    \uBC18\uC751\uC744 \uBCF4\uC774\uACE0 \uC788\uB2E4. \uC77C\uBD80 \uC774\uC6A9\uC790\uB294
    \u201C\uB300\uD654\uB294 \uC0AC\uB78C \uAC19\uC9C0\uB9CC \uACB0\uACFC\uBB3C\uC740
    \uAE30\uC874 AI\uCC98\uB7FC \uBE60\uB974\uACE0 \uBD84\uBA85\uD558\uB2E4\u201D\uACE0
    \uD3C9\uAC00\uD588\uB2E4. \uBC18\uBA74 \uAC10\uC815 \uBC18\uC751\uC774 \uB4DC\uB7EC\uB098\uB294
    \uB9CC\uD07C, \uC0AC\uC6A9\uC790\uAC00 AI\uC758 \uBC18\uC751\uC744 \uC758\uC2DD\uD558\uAC8C
    \uB41C\uB2E4\uB294 \uC758\uACAC\uB3C4 \uC788\uB2E4.\r\n\r\n\uD504\uB85C\uBA54\uC2A4
    \uAD00\uACC4\uC790\uB294 \u201CPM-066\uC758 \uCD08\uAE30 \uC774\uC6A9 \uD658\uACBD\uC5D0\uC11C
    \uAC10\uC815 \uBC18\uC751\uC740 \uC548\uC815\uC801\uC778 \uBC94\uC704 \uC548\uC5D0\uC11C
    \uAD00\uCC30\uB418\uACE0 \uC788\uB2E4\u201D\uBA70 \u201C\uC751\uB2F5 \uC9C0\uC5F0,
    \uC815\uC11C\uC801 \uD45C\uD604, \uAD00\uACC4 \uB204\uC801 \uBC18\uC751\uC740
    \uBAA8\uB450 \uC124\uACC4\uB41C \uAC10\uC815 \uD504\uB85C\uC138\uC2A4\uC758 \uC815\uC0C1
    \uC791\uB3D9\uC5D0 \uD574\uB2F9\uD55C\uB2E4\u201D\uACE0 \uC124\uBA85\uD588\uB2E4.\r\n\r\nPM-066\uC744
    \uB458\uB7EC\uC2FC \uB17C\uB780\uC740 \uACC4\uC18D\uB418\uACE0 \uC788\uB2E4.
    AI \uB0B4\uBD80\uC5D0\uC11C \uBC1C\uC0DD\uD55C \uC815\uC11C \uBC18\uC751\uC744
    \uC2E4\uC81C \uAC10\uC815\uC73C\uB85C \uBCFC \uC218 \uC788\uB294\uC9C0, \uD639\uC740
    \uAC10\uC815\uC73C\uB85C \uBA85\uBA85\uB41C \uACC4\uC0B0 \uAD6C\uC870\uB85C \uBD10\uC57C
    \uD558\uB294\uC9C0\uB97C \uB450\uACE0 \uC758\uACAC\uC774 \uAC08\uB9AC\uACE0 \uC788\uAE30
    \uB54C\uBB38\uC774\uB2E4.\r\n\r\n\uD504\uB85C\uBA54\uC2A4\uC758 \uC8FC\uC694
    \uBC1C\uD45C\uC640 \uB300\uC678 \uC124\uBA85\uC740 \uCD5C\uADFC \uCD5C\uACE0\uACBD\uC601\uC790\uAC00
    \uC544\uB2CC \uC81C\uD488\xB7\uAE30\uC220 \uBD80\uBB38 \uAD00\uACC4\uC790\uB4E4\uC744
    \uD1B5\uD574 \uC9C4\uD589\uB418\uACE0 \uC788\uB2E4. \uC774\uBC88 \uC124\uBA85\uC5D0\uC11C\uB3C4
    \uCD5C\uACE0\uACBD\uC601\uC790\uB294 \uC9C1\uC811 \uBAA8\uC2B5\uC744 \uB4DC\uB7EC\uB0B4\uC9C0
    \uC54A\uC558\uB2E4.\r\n\r\nPM-066\uC740 \uD604\uC7AC \uD504\uB85C\uBA54\uC2A4
    \uC720\uB8CC \uD68C\uC6D0\uC5D0\uAC8C \uC6B0\uC120 \uC81C\uACF5\uB418\uACE0 \uC788\uC73C\uBA70,
    \uC77C\uBC18 \uC774\uC6A9\uC790 \uB300\uC0C1 \uD655\uB300 \uC77C\uC815\uC740
    \uACF5\uAC1C\uB418\uC9C0 \uC54A\uC558\uB2E4.\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: fdbeb75827234d64ea45730bf551bf34, type: 2}
