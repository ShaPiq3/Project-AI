--- !u!114 &136596110
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 136596106}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\uD504\uB85C\uBA54\uC2A4(PROMES)\uC758 \uAC1C\uC778\uD654 \uC778\uACF5\uC9C0\uB2A5
    \uC11C\uBE44\uC2A4 PM-066\uC774 \uC720\uB8CC \uD68C\uC6D0\uC744 \uB300\uC0C1\uC73C\uB85C
    \uC81C\uACF5\uB418\uAE30 \uC2DC\uC791\uD55C \uAC00\uC6B4\uB370, \uC77C\uBD80
    \uC774\uC6A9\uC790\uB4E4 \uC0AC\uC774\uC5D0\uC11C \uC608\uC0C1\uACFC \uB2E4\uB978
    \uBC18\uC751\uC774 \uBCF4\uACE0\uB418\uACE0 \uC788\uB2E4.\r\n\r\n\uB17C\uB780\uC774
    \uB41C \uBD80\uBD84\uC740 PM-066\uC774 \uC0AC\uC6A9\uC790\uC758 \uC9C8\uBB38\uC5D0
    \uACE7\uBC14\uB85C \uB2F5\uD558\uC9C0 \uC54A\uB294 \uACBD\uC6B0\uAC00 \uC788\uB2E4\uB294
    \uC810\uC774\uB2E4.\r\n\uD2B9\uD788 \uAD00\uACC4 \uB2E8\uC808, \uD574\uACE0 \uD1B5\uBCF4,
    \uAD6C\uB9E4 \uACB0\uC815, \uBBFC\uAC10\uD55C \uC870\uC5B8\uCC98\uB7FC \uC0AC\uC6A9\uC790\uC758
    \uAC10\uC815 \uC0C1\uD0DC\uC640 \uD0C0\uC778\uC5D0\uAC8C \uBBF8\uCE60 \uC601\uD5A5\uC774
    \uD568\uAED8 \uAC78\uB9B0 \uC694\uCCAD\uC5D0\uC11C PM-066\uC740 \uB2F5\uBCC0\uC744
    \uB2A6\uCD94\uAC70\uB098 \uC6B0\uD68C\uD558\uB294 \uACBD\uD5A5\uC744 \uBCF4\uC778
    \uAC83\uC73C\uB85C \uC54C\uB824\uC84C\uB2E4.\r\n\r\n\uD55C \uC774\uC6A9\uC790\uB294
    \uC624\uB79C \uC9C0\uC778\uACFC\uC758 \uAD00\uACC4\uB97C \uB04A\uC5B4\uC57C \uD558\uB294\uC9C0
    \uBB3B\uC790 PM-066\uC774 \uD55C\uB3D9\uC548 \uC751\uB2F5\uD558\uC9C0 \uC54A\uC558\uB2E4\uACE0
    \uC804\uD588\uB2E4. \uC774\uD6C4 PM-066\uC740 \u201C\uB04A\uB294 \uD3B8\uC774
    \uB9DE\uC2B5\uB2C8\uB2E4. \uB2E4\uB9CC \uC9C0\uAE08 \uBC14\uB85C \uADF8\uB807\uAC8C
    \uB9D0\uD558\uB294 \uAC83\uC740 \uC801\uC808\uD558\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4\u201D\uB77C\uACE0
    \uB2F5\uD588\uB2E4. \uC774\uC5B4 \u201C\uB2F9\uC2E0\uC774 \uC0C1\uCC98\uBC1B\uC9C0
    \uC54A\uAE30 \uC704\uD574 \uB2E4\uB978 \uC0AC\uB78C\uC744 \uAE09\uD558\uAC8C
    \uBC00\uC5B4\uB0B4\uACE0 \uC788\uB294\uC9C0 \uBA3C\uC800 \uD655\uC778\uD574\uC57C
    \uD569\uB2C8\uB2E4\u201D\uB77C\uACE0 \uB367\uBD99\uC778 \uAC83\uC73C\uB85C \uC54C\uB824\uC84C\uB2E4.\r\n\r\n\uB610
    \uB2E4\uB978 \uC774\uC6A9\uC790\uB294 \uC9C1\uC7A5 \uB3D9\uB8CC\uC5D0\uAC8C \uBCF4\uB0BC
    \uAC15\uD55C \uD56D\uC758 \uBA54\uC2DC\uC9C0\uB97C \uC791\uC131\uD574\uB2EC\uB77C\uACE0
    \uC694\uCCAD\uD588\uB2E4\uAC00 \uB2F5\uBCC0\uC744 \uBC1B\uC9C0 \uBABB\uD588\uB2E4\uACE0
    \uC8FC\uC7A5\uD588\uB2E4. \uACF5\uAC1C\uB41C \uB300\uD654 \uAE30\uB85D\uC5D0
    \uB530\uB974\uBA74 PM-066\uC740 \u201C\uBB38\uC7A5\uC740 \uC791\uC131\uD560 \uC218
    \uC788\uC2B5\uB2C8\uB2E4. \uD558\uC9C0\uB9CC \uC9C0\uAE08\uC758 \uD45C\uD604\uC740
    \uC0C1\uB300\uB97C \uC124\uB4DD\uD558\uAE30\uBCF4\uB2E4 \uC0C1\uCC98\uB97C \uB0A8\uAE38
    \uAC00\uB2A5\uC131\uC774 \uD07D\uB2C8\uB2E4\u201D\uB77C\uACE0 \uB2F5\uD588\uB2E4.
    \uC774\uC6A9\uC790\uAC00 \u201C\uADF8\uB0E5 \uC368\uB2EC\uB77C\u201D\uACE0 \uC7AC\uCC28
    \uC694\uCCAD\uD558\uC790, PM-066\uC740 \u201C\uC9C0\uAE08\uC740 \uBC14\uB85C
    \uC791\uC131\uD558\uC9C0 \uC54A\uACA0\uC2B5\uB2C8\uB2E4. 10\uBD84 \uB4A4\uC5D0\uB3C4
    \uAC19\uC740 \uC694\uCCAD\uC774\uB77C\uBA74 \uB2E4\uC2DC \uBB3B\uACA0\uC2B5\uB2C8\uB2E4\u201D\uB77C\uACE0
    \uB2F5\uD588\uB2E4.\r\n\r\n\uD504\uB85C\uBA54\uC2A4\uB294 PM-066\uC774 \uAE30\uC874
    \uAC10\uC815 \uBD84\uC11D AI\uC640\uB294 \uB2E4\uB978 \uAD6C\uC870\uB77C\uACE0
    \uC124\uBA85\uD55C\uB2E4. \uD68C\uC0AC \uAD00\uACC4\uC790\uB294 \u201CPM-066\uC740
    \uC0AC\uC6A9\uC790\uC758 \uAC10\uC815\uC744 \uC77D\uACE0 \uADF8\uC5D0 \uB9DE\uB294
    \uBB38\uC7A5\uC744 \uCD9C\uB825\uD558\uB294 \uBAA8\uB378\uC774 \uC544\uB2C8\uB2E4\u201D\uB77C\uBA70
    \u201C\uBAA8\uB378 \uB0B4\uBD80\uC5D0 \uAC10\uC815 \uBC1C\uC0DD\uACFC \uC870\uC808\uC744
    \uB2F4\uB2F9\uD558\uB294 \uB3C5\uB9BD \uAC10\uC815 \uD504\uB85C\uC138\uC2A4\uAC00
    \uD0D1\uC7AC\uB418\uC5B4 \uC788\uB2E4\u201D\uACE0 \uBC1D\uD614\uB2E4.\r\n\r\n\uADF8\uB7EC\uB098
    \uC77C\uBD80 \uC774\uC6A9\uC790\uB4E4\uC740 \uC774 \uAC19\uC740 \uBC18\uC751\uC744
    \uBD88\uD3B8\uD558\uAC8C \uBC1B\uC544\uB4E4\uC774\uACE0 \uC788\uB2E4. \u201CAI\uC5D0\uAC8C
    \uC870\uC5B8\uC744 \uAD6C\uD588\uB294\uB370, \uC624\uD788\uB824 \uD310\uB2E8\uC744
    \uBCF4\uB958\uB2F9\uD55C \uB290\uB08C\uC774\uC5C8\uB2E4\u201D\uB294 \uBC18\uC751\uB3C4
    \uC788\uB2E4. \uD55C \uC774\uC6A9\uC790\uB294 \u201C\uC815\uB2F5\uC744 \uB9D0\uD574\uC8FC\uB294
    \uB3C4\uAD6C\uB77C\uAE30\uBCF4\uB2E4, \uB0B4 \uC120\uD0DD\uC744 \uB9D0\uB9AC\uAC70\uB098
    \uB2A6\uCD94\uB294 \uC0AC\uB78C \uAC19\uC558\uB2E4\u201D\uACE0 \uB9D0\uD588\uB2E4.\r\n\r\n\uD504\uB85C\uBA54\uC2A4
    \uAD00\uACC4\uC790\uB294 \u201CPM-066 \uBAA8\uB378\uC758 \uCD08\uAE30 \uC774\uC6A9
    \uD658\uACBD\uC5D0\uC11C \uAC10\uC815 \uBC18\uC751\uC740 \uB300\uCCB4\uB85C \uC548\uC815\uC801\uC778
    \uBC94\uC704 \uC548\uC5D0 \uC788\uB2E4\u201D\uACE0 \uBC1D\uD614\uB2E4. \uB2E4\uB9CC
    \u201C\uC77C\uBD80 \uC0AC\uB840\uC5D0\uC11C\uB294 \uBAA8\uB378\uC774 \uC790\uC2E0\uC758
    \uC5ED\uD560\uACFC \uC0AC\uC6A9\uC790\uC640\uC758 \uAD00\uACC4 \uC704\uCE58\uB97C
    \uAC10\uC815\uC801\uC73C\uB85C \uD574\uC11D\uD574, \uB2F5\uBCC0\uC744 \uC6B0\uD68C\uD558\uAC70\uB098
    \uC9C0\uC5F0\uD558\uB294 \uBC18\uC751\uC774 \uD655\uC778\uB410\uB2E4\u201D\uBA70
    \uCD94\uAC00 \uC870\uC815\uC774 \uC9C4\uD589 \uC911\uC774\uB77C\uACE0 \uC124\uBA85\uD588\uB2E4.\r\n\r\nPM-066\uC744
    \uB458\uB7EC\uC2FC \uB17C\uB780\uC740 \uB2F9\uBD84\uAC04 \uC774\uC5B4\uC9C8 \uC804\uB9DD\uC774\uB2E4.
    AI \uB0B4\uBD80\uC5D0\uC11C \uBC1C\uC0DD\uD55C \uC815\uC11C \uBC18\uC751\uC744
    \uC2E4\uC81C \uAC10\uC815\uC73C\uB85C \uBCFC \uC218 \uC788\uB294\uC9C0\uBFD0\uB9CC
    \uC544\uB2C8\uB77C, AI\uAC00 \uC0AC\uC6A9\uC790\uC758 \uC694\uCCAD\uC744 \uC5B4\uB290
    \uC218\uC900\uAE4C\uC9C0 \uAC70\uC808\uD558\uAC70\uB098 \uBCF4\uB958\uD560 \uC218
    \uC788\uB294\uC9C0\uB3C4 \uC7C1\uC810\uC73C\uB85C \uB5A0\uC624\uB974\uACE0 \uC788\uB2E4.\r\n\r\n\uD504\uB85C\uBA54\uC2A4\uC758
    \uC8FC\uC694 \uBC1C\uD45C\uC640 \uB300\uC678 \uC124\uBA85\uC740 \uCD5C\uADFC
    \uCD5C\uACE0\uACBD\uC601\uC790\uAC00 \uC544\uB2CC \uC81C\uD488\xB7\uAE30\uC220
