--- !u!114 &2093963964
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2093963960}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\uC218\uB3C4\uAD8C \uC8FC\uC694 \uAD6C\uAC04\uC758 \uC57C\uAC04 \uD1B5\uD589\uB7C9\uC774
    SoopSeek \uC870\uC815\uC548\uC5D0 \uB530\uB77C \uC790\uB3D9 \uC81C\uD55C\uB41C
    \uC774\uD6C4 \uAD50\uD1B5 \uD63C\uC7A1\uB960\uC774 \uD06C\uAC8C \uC904\uC5B4\uB4E0
    \uAC83\uC73C\uB85C \uB098\uD0C0\uB0AC\uB2E4.\r\n\r\n\uAD6D\uD1A0\uAD00\uB9AC\uBD80
    \uB3C4\uC2DC\uD750\uB984\uC870\uC815\uAD6D\uC740 \uC9C0\uB09C 22\uC77C \u201C\uC9C0\uB09C
    \uD55C \uB2EC\uAC04 \uC218\uB3C4\uAD8C \uC81C3\uC21C\uD658\uCD95\uACFC \uD558\uB0A8\uC2A4\uB9C8\uD2B8\uC9C0\uAD6C
    \uC77C\uB300\uC758 \uC57C\uAC04 \uC774\uB3D9 \uB370\uC774\uD130\uB97C \uBD84\uC11D\uD55C
    \uACB0\uACFC, \uD3C9\uADE0 \uD63C\uC7A1\uB960\uC774 \uC804\uC6D4 \uB300\uBE44
    31.2% \uAC10\uC18C\uD588\uB2E4\u201D\uACE0 \uBC1D\uD614\uB2E4.\r\n\r\n\uC774\uBC88
    \uC870\uCE58\uB294 SoopSeek\uAC00 \uC0B0\uCD9C\uD55C \u2018\uC57C\uAC04 \uB3C4\uC2DC
    \uD6A8\uC728\uD654 \uAD8C\uACE0\uC548\u2019\uC5D0 \uB530\uB978 \uAC83\uC774\uB2E4.
    \uD574\uB2F9 \uAD8C\uACE0\uC548\uC740 \uAD50\uD1B5\uB7C9, \uBC94\uC8C4 \uC2E0\uACE0
    \uBC00\uB3C4, \uC751\uAE09 \uB85C\uBD07 \uCD9C\uB3D9 \uACBD\uB85C, \uBC30\uC1A1
    \uB4DC\uB860 \uD56D\uB85C, \uC5D0\uB108\uC9C0 \uC0AC\uC6A9\uB7C9 \uB4F1\uC744
    \uC885\uD569\uD574 \uC2DC\uAC04\uB300\uBCC4 \uC774\uB3D9 \uAD8C\uC7A5 \uAD6C\uAC04\uC744
    \uC7AC\uBC30\uCE58\uD558\uB294 \uB0B4\uC6A9\uC744 \uB2F4\uACE0 \uC788\uB2E4.\r\n\r\n\uC774\uC5D0
    \uB530\uB77C \uC77C\uBD80 \uAD6C\uAC04\uC5D0\uC11C\uB294 \uC624\uD6C4 11\uC2DC
    \uC774\uD6C4 \uC77C\uBC18 \uCC28\uB7C9 \uC9C4\uC785\uC774 \uC790\uB3D9 \uC81C\uD55C\uB418\uACE0,
    \uC751\uAE09\xB7\uBC30\uC1A1\xB7\uD589\uC815 \uB85C\uBD07\uC758 \uC774\uB3D9\uC774
    \uC6B0\uC120 \uBC30\uC815\uB41C\uB2E4. \uC2DC\uBBFC \uCC28\uB7C9\uC740 Pro Earth
    \uACBD\uB85C \uC548\uB0B4\uC5D0 \uB530\uB77C \uC6B0\uD68C\uB85C\uB97C \uBC30\uC815\uBC1B\uB294\uB2E4.\r\n\r\n\uAD6D\uD1A0\uAD00\uB9AC\uBD80
    \uB3C4\uC2DC\uD750\uB984\uC870\uC815\uAD6D \uAD00\uACC4\uC790\uB294 \u201C\uC2DC\uBBFC
    \uC774\uB3D9\uC744 \uC81C\uD55C\uD558\uB294 \uC870\uCE58\uAC00 \uC544\uB2C8\uB77C
    \uB3C4\uC2DC \uC804\uCCB4\uC758 \uD750\uB984\uC744 \uCD5C\uC801\uD654\uD558\uB294
    \uACFC\uC815\u201D\uC774\uB77C\uBA70 \u201C\uBD88\uD544\uC694\uD55C \uC57C\uAC04
    \uC774\uB3D9\uC744 \uC904\uC774\uACE0 \uD544\uC218 \uC774\uB3D9\uC744 \uC6B0\uC120
    \uCC98\uB9AC\uD558\uB294 \uAC83\uC774 \uD575\uC2EC\u201D\uC774\uB77C\uACE0 \uC124\uBA85\uD588\uB2E4.\r\n\r\n\uC77C\uBD80
    \uC2DC\uBBFC\uB4E4\uC740 \uAC11\uC791\uC2A4\uB7EC\uC6B4 \uC6B0\uD68C \uACBD\uB85C
    \uBC30\uC815\uC5D0 \uBD88\uD3B8\uC744 \uD638\uC18C\uD588\uB2E4. \uD558\uB0A8
    \uC2A4\uB9C8\uD2B8\uC9C0\uAD6C\uC5D0 \uAC70\uC8FC\uD558\uB294 \uC9C1\uC7A5\uC778
    A\uC528\uB294 \u201C\uD1F4\uADFC\uAE38\uC774 \uD3C9\uC18C\uBCF4\uB2E4 18\uBD84
    \uAE38\uC5B4\uC84C\uC9C0\uB9CC, \uACBD\uB85C \uC548\uC815\uB3C4\uB294 \uB354
    \uB192\uAC8C \uD45C\uC2DC\uB410\uB2E4\u201D\uBA70 \u201C\uADF8\uB807\uAC8C \uC548\uB0B4\uB418\uB2C8
    \uB530\uB97C \uC218\uBC16\uC5D0 \uC5C6\uC5C8\uB2E4\u201D\uACE0 \uB9D0\uD588\uB2E4.\r\n\r\n\uC815\uBD80\uB294
    \uB2E4\uC74C \uBD84\uAE30\uBD80\uD130 \uC57C\uAC04 \uD1B5\uD589\uB7C9 \uC870\uC815
    \uB300\uC0C1\uC744 \uC9C0\uBC29 \uAD11\uC5ED\uC2DC\uB85C \uD655\uB300\uD560 \uACC4\uD68D\uC774\uB2E4."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: fdbeb75827234d64ea45730bf551bf34, type: 2}
