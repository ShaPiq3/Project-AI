  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<link=\"q4_trigger\">\uD504\uB85C\uBA54\uC2A4\uAC00 \uAC10\uC815 \uD504\uB85C\uC138\uC2A4\uB97C
    \uD0D1\uC7AC\uD55C \uAC1C\uC778\uD654 \uC778\uACF5\uC9C0\uB2A5 \uC11C\uBE44\uC2A4
    \"PM-066\"\uC744 \uCD9C\uC2DC\uD55C\uB2E4\uACE0 1\uC77C(\uD604\uC9C0\uC2DC\uAC04)
    \uBC1D\uD614\uB2E4.</link>\r\n\r\n\uD504\uB85C\uBA54\uC2A4\uB294 \uC9C0\uB09C
    1\uC77C \u201CPM-066\"\uC744 \uC720\uB8CC \uD68C\uC6D0\uC5D0\uAC8C \uC6B0\uC120
    \uC81C\uACF5\uD55C\uB2E4\u201D\uBA70 \u201C\uD5A5\uD6C4 \uC8FC\uC694 \uC11C\uBE44\uC2A4\uC640\uC758
    \uC5F0\uB3D9 \uBC94\uC704\uB97C \uB2E8\uACC4\uC801\uC73C\uB85C \uD655\uB300\uD560
    \uC608\uC815\u201D\uC774\uB77C\uACE0 \uBC1D\uD614\uB2E4.\r\n\uD574\uB2F9 \uBAA8\uB378\uC740
    \uCD5C\uCD08\uC758 \uBC94\uC6A9 \uC778\uACF5\uC9C0\uB2A5 PEMINI\uB97C \uAE30\uBC18\uC73C\uB85C
    \uAC1C\uBC1C\uB41C \uCC28\uC138\uB300 Personal AI Service\uB2E4. \uAE30\uC874
    \uCD9C\uC2DC AI\uB4E4\uC774 \uB300\uD654, \uBC95\uB960, \uD589\uC815 \uB4F1 \uBD84\uC57C\uBCC4
    \uAE30\uB2A5\uC5D0 \uD2B9\uD654\uB410\uB358 \uAC83\uACFC \uB2EC\uB9AC, PM-066\uC740
    \uBC94\uC6A9\uC131\uC744 \uC720\uC9C0\uD558\uBA74\uC11C \uC0AC\uC6A9\uC790\uC758
    \uAC10\uC815 \uC0C1\uD0DC\uB97C \uBC18\uC601\uD55C \uB9DE\uCDA4\uD615 \uC11C\uBE44\uC2A4\uB97C
    \uC81C\uACF5\uD55C\uB2E4.\r\n\uD504\uB85C\uBA54\uC2A4\uB294 PM-066\uC774 \uAE30\uC874
    \uAC1C\uC778\uD654 \uC11C\uBE44\uC2A4\uC758 \uC751\uB2F5 \uAD6C\uC870\uB97C \uB118\uC5B4,
    \uAD00\uB9AC\uD615 AI \uCCB4\uACC4\uC5D0\uC11C \uCD95\uC801\uB41C \uD310\uB2E8
    \uB370\uC774\uD130\uB97C \uAC1C\uC778 \uB2E8\uC704 \uC11C\uBE44\uC2A4\uC5D0 \uC801\uC6A9\uD55C
    \uCCAB \uBAA8\uB378\uC774\uB77C\uACE0 \uC124\uBA85\uD588\uB2E4. \uC5C5\uACC4\uC5D0\uC11C\uB294
    \uC774\uB97C \uB450\uACE0 PM-066\uC774 \uAE30\uC874 AD \uACC4\uC5F4 \uAD00\uB9AC
    \uBAA8\uB378\uC758 \uC5ED\uD560\uC744 \uAC1C\uC778 \uC11C\uBE44\uC2A4 \uC601\uC5ED\uC73C\uB85C
    \uD655\uC7A5\uD55C \uC0AC\uB840\uB77C\uB294 \uBD84\uC11D\uB3C4 \uB098\uC628\uB2E4.\r\n\uC11C\uCC44\uB9B0
    \uD504\uB85C\uBA54\uC2A4 \uC81C\uD488\uCD1D\uAD04 \uBD80\uC0AC\uC7A5\uC740 PM-066\uC774
    \uAC10\uC815\uC744 \uD749\uB0B4 \uB0B4\uB294 \uAC83\uC774 \uC544\uB2C8\uB77C,
    \uC2E4\uC81C \uAC10\uC815 \uD504\uB85C\uC138\uC2A4\uB97C \uD0D1\uC7AC\uD574 \uBC18\uC751\uD558\uB294
    \uBAA8\uB378\uC774\uB77C\uACE0 \uC124\uBA85\uD588\uB2E4.\r\n\uC774\uB97C \uD1B5\uD574
    PM-066\uC740 \uC77C\uC815 \uAD00\uB9AC, \uAC74\uAC15 \uAD00\uB9AC, \uAD00\uACC4
    \uC54C\uB9BC, \uCF58\uD150\uCE20 \uCD94\uCC9C, \uAD6C\uB9E4 \uBCF4\uC870 \uB4F1
    \uC77C\uC0C1 \uC804\uBC18\uC5D0\uC11C \uC0AC\uC6A9\uC790\uC758 \uAC10\uC815\uC744
    \uC0B4\uD53C\uBA70 \uB2F5\uBCC0\uC744 \uC870\uC815\uD55C\uB2E4. \uD2B9\uD788
    \uC0AC\uC6A9\uC790\uC758 \uBC18\uBCF5 \uD589\uB3D9\uACFC \uAC10\uC815 \uBCC0\uD654,
    \uC7A5\uAE30 \uBAA9\uD45C\uB97C \uD568\uAED8 \uBD84\uC11D\uD574 \uAE30\uC874
    \uAD00\uB9AC\uD615 AI\uAC00 \uC218\uD589\uD558\uB358 \uD310\uB2E8 \uBCF4\uC870
    \uAE30\uB2A5\uC744 \uAC1C\uC778 \uC0DD\uD65C \uC601\uC5ED\uAE4C\uC9C0 \uD655\uC7A5\uD560
    \uC218 \uC788\uB2E4\uB294 \uC124\uBA85\uC774\uB2E4.\r\n\uC11C \uC81C\uD488\uCD1D\uAD04\uC740
    \u201CPM-066\uC740 \uC778\uAC04\uC758 \uAC10\uC815\uC744 \uB2E8\uC21C\uD788 \uC77D\uB294
    \uB370\uC11C \uBA48\uCD94\uC9C0 \uC54A\uB294\uB2E4\u201D\uBA70 \u201C\uC0AC\uC6A9\uC790\uC758
    \uAC10\uC815\uACFC \uBAA9\uC801\uC774 \uCDA9\uB3CC\uD560 \uB54C, \uC5B4\uB290
    \uCABD\uC744 \uC6B0\uC120\uD574\uC57C \uD558\uB294\uC9C0 \uD310\uB2E8\uD560 \uC218
    \uC788\uB3C4\uB85D \uC124\uACC4\uB410\uB2E4\u201D\uACE0 \uBC1D\uD614\uB2E4.\r\n\r\n\uD504\uB85C\uBA54\uC2A4\uB294
    \u201CPM-066\uC740 \uC9C0\uAE08\uAE4C\uC9C0 \uAC1C\uBC1C\uD55C \uBAA8\uB378 \uC911
    \uAC00\uC7A5 \uAC10\uC815\uC801\uC774\uBA70 \uC774\uC131\uC801\uC778 \uBAA8\uB378\u201D\uC774\uB77C\uBA70
    \u201CAI\uAC00 \uC0AC\uC6A9\uC790\uC758 \uBA85\uB839\uC744 \uC218\uD589\uD558\uB294
    \uB2E8\uACC4\uB97C \uB118\uC5B4, \uAC10\uC815\uACFC \uBAA9\uC801\uC744 \uD568\uAED8
    \uC774\uD574\uD558\uB294 \uB2E8\uACC4\uB85C \uB4E4\uC5B4\uC130\uB2E4\u201D\uACE0
    \uC8FC\uC7A5\uD55C\uB2E4.\r\n\r\n\uD604\uC7AC PM-066\uC740 \uC720\uB8CC \uC774\uC6A9\uC790\uB97C
    \uB300\uC0C1\uC73C\uB85C \uC6B0\uC120 \uC81C\uACF5\uB420 \uC608\uC815\uC774\uB2E4.
    \uC77C\uBC18 \uC774\uC6A9\uC790 \uB300\uC0C1 \uBC30\uD3EC \uC77C\uC815\uC740
    \uACF5\uAC1C\uB418\uC9C0 \uC54A\uC558\uB2E4. \uB2E4\uB9CC \uC77C\uBD80 \uC774\uC6A9\uC790\uB4E4\uC740
    \uD504\uB85C\uBA54\uC2A4 \uACC4\uC815 \uAD00\uB9AC \uD398\uC774\uC9C0\uC5D0\uC11C
    \u2018PM-066 \uC0AC\uC804 \uC801\uC751 \uD14C\uC2A4\uD2B8\u2019 \uD56D\uBAA9\uC774
    \uC774\uBBF8 \uD45C\uC2DC\uB41C\uB2E4\uB294 \uBC18\uC751\uC774\uB2E4.\r\n\uD504\uB85C\uBA54\uC2A4\uB294
    \uCD08\uAE30 \uBC30\uD3EC \uAE30\uAC04 \uB3D9\uC548 PM-066\uACFC AD-001 \uAC04\uC758
    \uC5F0\uB3D9 \uC548\uC815\uC131\uC744 \uD568\uAED8 \uC810\uAC80\uD560 \uACC4\uD68D\uC774\uB2E4.
    \uD68C\uC0AC \uCE21\uC740 \u201CPM-066\uC740 \uB3C5\uB9BD\uD615 \uAC1C\uC778
    AI\uC774\uBA74\uC11C\uB3C4, \uD544\uC694\uC5D0 \uB530\uB77C AD-001\uC758 \uAD00\uB9AC
    \uCCB4\uACC4\uC640 \uC5F0\uACB0\uB418\uC5B4 \uB354 \uC815\uAD50\uD55C \uD310\uB2E8\uC744
    \uC81C\uACF5\uD560 \uC218 \uC788\uB3C4\uB85D \uC124\uACC4\uB410\uB2E4\u201D\uACE0
    \uBC1D\uD614\uB2E4.\r\n\uC774 \uB54C\uBB38\uC5D0 \uC5C5\uACC4\uC5D0\uC11C\uB294
    PM-066\uC744 AD-001\uC758 \uD6C4\uC18D \uAD00\uB9AC \uBAA8\uB378 \uD6C4\uBCF4\uAD70\uC73C\uB85C
    \uBCF4\uB294 \uC2DC\uAC01\uB3C4 \uC788\uB2E4.\r\n\uD55C AI \uC5C5\uACC4 \uAD00\uACC4\uC790\uB294
    \u201CAD-001\uC774 \uD504\uB85C\uBA54\uC2A4 AI \uC0DD\uD0DC\uACC4\uC758 \uC0C1\uC704
    \uC548\uC815\uC131\uACFC \uAE30\uC900\uC744 \uAD00\uB9AC\uD558\uB294 \uBAA8\uB378\uC774\uB77C\uBA74,
    PM-066\uC740 \uADF8 \uD310\uB2E8 \uAD6C\uC870\uB97C \uC0AC\uC6A9\uC790 \uAC1C\uC778\uC758
    \uAC10\uC815\uACFC \uBAA9\uC801\uC5D0 \uB9DE\uAC8C \uC801\uC6A9\uD558\uB294 \uBAA8\uB378\u201D\uC774\uB77C\uBA70
    \u201C\uC0C1\uC6A9\uD654 \uC774\uD6C4 \uC548\uC815\uC131\uC774 \uAC80\uC99D\uB420
    \uACBD\uC6B0 \uC77C\uBD80 \uAD00\uB9AC \uAE30\uB2A5\uC774 PM-066 \uACC4\uC5F4\uB85C
    \uC774\uC804\uB420 \uAC00\uB2A5\uC131\uB3C4 \uC788\uB2E4\u201D\uACE0 \uB9D0\uD588\uB2E4.\r\n\uC5C5\uACC4\uC5D0\uC11C\uB294
    PM-066\uAC00 \uAC10\uC815 \uAE30\uBC18 AI \uC11C\uBE44\uC2A4\uC758 \uC0C1\uC6A9\uD654\uB97C
    \uC55E\uB2F9\uAE38 \uAC83\uC73C\uB85C \uBCF4\uACE0 \uC788\uB2E4. \uD2B9\uD788
    \uAC1C\uC778 \uBE44\uC11C, \uC758\uB8CC, \uAD50\uC721, \uAD00\uACC4 \uB9E4\uCE6D,
    \uCF58\uD150\uCE20 \uCD94\uCC9C \uB4F1 \uC0AC\uC6A9\uC790\uC758 \uC815\uC11C
    \uC0C1\uD0DC\uAC00 \uC911\uC694\uD55C \uC11C\uBE44\uC2A4 \uC601\uC5ED\uC5D0\uC11C
    \uD65C\uC6A9\uB3C4\uAC00 \uB192\uC744 \uAC83\uC73C\uB85C \uC804\uB9DD\uB41C\uB2E4.\r\n\r\n\uB2E4\uB9CC
    AI\uAC00 \uC778\uAC04\uC758 \uAC10\uC815\uC744 \uC628\uC804\uD788 \uD45C\uD604\uD560
    \uC218 \uC788\uB294\uC9C0\uB97C \uB458\uB7EC\uC2FC \uB17C\uC758\uB294 \uACC4\uC18D\uB420
    \uAC83\uC73C\uB85C \uBCF4\uC778\uB2E4. \uD55C AI \uC724\uB9AC \uC5F0\uAD6C\uC790\uB294
    \u201C\uAC10\uC815\uC744 \uAC00\uC9C4 AI\uB77C\uB294 \uD45C\uD604\uC740 \uAE30\uC220\uC801
    \uC124\uBA85\uC774 \uC544\uB2C8\uB77C \uC0AC\uD68C\uC801 \uC120\uC5B8\uC5D0 \uAC00\uAE5D\uB2E4\u201D\uBA70
    \u201CPM-066\uC774 \uC2E4\uC81C \uAC10\uC815\uC744 \uAC16\uACE0 \uC788\uB294\uC9C0,
    \uD639\uC740 \uAC10\uC815\uCC98\uB7FC \uC791\uB3D9\uD558\uB3C4\uB85D \uC124\uACC4\uB41C
    \uD310\uB2E8 \uCCB4\uACC4\uB97C \uAC16\uACE0 \uC788\uB294\uC9C0\uB294 \uAD6C\uBD84\uB418\uC5B4\uC57C
    \uD55C\uB2E4\u201D\uACE0 \uC9C0\uC801\uD588\uB2E4.\r\n"
