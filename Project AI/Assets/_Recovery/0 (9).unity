--- !u!114 &648942327
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 648942323}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\uBCF4\uD638\uC790 \uC54C\uB9BC \uAE30\uB2A5\uC744 \uB048 \uCC44 \uC0DD\uD65C\uD558\uB358
    70\uB300 \uB0A8\uC131\uC774 \uBCF5\uC9C0 AI \uBBF8\uC751\uB2F5 \uD655\uC778 \uC808\uCC28\uB97C
    \uD1B5\uD574 \uBC1C\uACAC\uB410\uB2E4.\r\n\uC2E0\uC11C\uC6B8\uC2DC \uBCF5\uC9C0\uC548\uC804\uC13C\uD130\uB294
    \uC9C0\uB09C 19\uC77C \uC624\uC804 9\uC2DC\uCBE4 \uAD00\uB0B4 \uAC70\uC8FC\uC790\uC778
    \uBC15\uBAA8 \uC528(74)\uC758 \uC77C\uC0C1 \uC751\uB2F5 \uAE30\uB85D\uC774 36\uC2DC\uAC04
    \uC774\uC0C1 \uD655\uC778\uB418\uC9C0 \uC54A\uC790 \uD604\uC7A5 \uD655\uC778
    \uC778\uB825\uC744 \uD30C\uACAC\uD588\uB2E4\uACE0 \uBC1D\uD614\uB2E4.\n\r\n\uBC15
    \uC528\uB294 \uC790\uD0DD \uAC70\uC2E4\uC5D0\uC11C \uC5B4\uC9C0\uB7FC\uC99D\uC744
    \uD638\uC18C\uD55C \uB4A4 \uC6C0\uC9C1\uC774\uC9C0 \uBABB\uD558\uACE0 \uC788\uC5C8\uC73C\uBA70,
    \uCD9C\uB3D9\uD55C \uBCF5\uC9C0 \uB2F4\uB2F9\uC790\uC640 WeGoDak \uC751\uAE09\uC9C0\uC6D0
    \uB85C\uBD07\uD300\uC5D0 \uC758\uD574 \uC11C\uAC15\uC0DD\uD65C\uC758\uB8CC\uAC80\uC0AC\uC18C\uB85C
    \uC774\uC1A1\uB410\uB2E4. \uC0DD\uBA85\uC5D0\uB294 \uC9C0\uC7A5\uC774 \uC5C6\uB294
    \uC0C1\uD0DC\uB85C \uC54C\uB824\uC84C\uB2E4.\n\r\n\uC2E0\uC11C\uC6B8\uC2DC\uC5D0
    \uB530\uB974\uBA74 \uBC15 \uC528\uB294 \uCD5C\uADFC \uBCF4\uD638\uC790 \uC54C\uB9BC
    \uAE30\uB2A5\uC744 \uC77C\uC2DC \uC911\uC9C0\uD55C \uC0C1\uD0DC\uC600\uB2E4.
    \uB2E4\uB9CC SoopSeek \uBCF5\uC9C0\uB9DD\uC5D0 \uB4F1\uB85D\uB41C \uACE0\uB839\uC790
    \uAE30\uBCF8 \uC548\uC804 \uD655\uC778 \uC808\uCC28\uB294 \uC720\uC9C0\uB418\uACE0
    \uC788\uC5B4, \uC77C\uC815 \uC2DC\uAC04 \uC774\uC0C1 \uC751\uB2F5\uC774 \uC5C6\uC744
    \uACBD\uC6B0 \uAD00\uD560 \uC13C\uD130\uC5D0 \uC790\uB3D9 \uBCF4\uACE0\uB418\uB3C4\uB85D
    \uC124\uC815\uB3FC \uC788\uC5C8\uB2E4.\n\r\n\uC2DC \uAD00\uACC4\uC790\uB294 \u201C\uBCF4\uD638\uC790
    \uC54C\uB9BC \uC5EC\uBD80\uC640 \uAD00\uACC4\uC5C6\uC774 \uACE0\uB839\uC790 \uAE30\uBCF8
    \uC548\uC804\uB9DD\uC740 \uBCC4\uB3C4\uB85C \uC791\uB3D9\uD55C\uB2E4\u201D\uBA70
    \u201C\uC774\uBC88 \uC0AC\uB840\uB3C4 \uBCF5\uC9C0 AI\uAC00 \uC0DD\uD65C \uD328\uD134\uC758
    \uAE09\uACA9\uD55C \uBCC0\uD654\uB97C \uAC10\uC9C0\uD574 \uD604\uC7A5 \uD655\uC778\uC73C\uB85C
    \uC774\uC5B4\uC9C4 \uACBD\uC6B0\u201D\uB77C\uACE0 \uC124\uBA85\uD588\uB2E4.\n\r\n\uD604\uC7AC
    \uC2E0\uC11C\uC6B8\uC2DC\uB294 1\uC778 \uAC00\uAD6C \uACE0\uB839\uC790, \uC911\uC99D\uC9C8\uD658\uC790,
    \uC7A5\uC560\uC778 \uB4F1\uC744 \uB300\uC0C1\uC73C\uB85C \uBCF5\uC9C0 AI \uD655\uC778\uB9DD\uC744
    \uC6B4\uC601\uD558\uACE0 \uC788\uB2E4. \uB300\uC0C1\uC790\uC758 \uC218\uBA74,
    \uC774\uB3D9, \uC2DD\uC0AC, \uC9C4\uB8CC \uC608\uC57D, \uC751\uB2F5 \uAE30\uB85D
    \uB4F1\uC744 \uC885\uD569\uD574 \uC774\uC0C1 \uC9D5\uD6C4\uAC00 \uD655\uC778\uB418\uBA74
    \uB2F4\uB2F9 \uBD80\uC11C\uC5D0 \uC790\uB3D9\uC73C\uB85C \uD1B5\uBCF4\uB41C\uB2E4.\r\n\uBC15
    \uC528\uC758 \uAC00\uC871\uC740 \u201C\uC54C\uB9BC \uAE30\uB2A5\uC744 \uAEBC\uB454
    \uC904 \uBAB0\uB790\uB2E4\u201D\uBA70 \u201C\uAE30\uBCF8 \uC548\uC804\uB9DD\uC774
    \uC720\uC9C0\uB418\uACE0 \uC788\uC5B4 \uB2E4\uD589\uC774\uC5C8\uB2E4\u201D\uACE0
    \uB9D0\uD588\uB2E4.\n\r\n\uC2DC\uB294 \uC774\uBC88 \uC0AC\uB840\uB97C \uBC14\uD0D5\uC73C\uB85C
    \uBCF4\uD638\uC790 \uC54C\uB9BC \uC911\uC9C0 \uC0C1\uD0DC\uC5D0\uC11C\uB3C4 \uC751\uAE09
    \uD655\uC778 \uC808\uCC28\uAC00 \uC815\uC0C1\uC801\uC73C\uB85C \uC791\uB3D9\uD558\uB294\uC9C0
    \uCD94\uAC00 \uC810\uAC80\uD560 \uC608\uC815\uC774\uB2E4.\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: fdbeb75827234d64ea45730bf551bf34, type: 2}
