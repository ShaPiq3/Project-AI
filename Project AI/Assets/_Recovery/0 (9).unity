  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\uC0AC\uB9DD\uC790\uC758 \uAE30\uC5B5 \uB370\uC774\uD130\uB97C \uAE30\uBC18\uC73C\uB85C
    \uAD6C\uC131\uD55C \uC804\uC2DC\uAC00 \uAC1C\uB9C9\uD588\uB2E4.\r\n\r\n\uAD6D\uB9BD\uD55C\uAC15\uBBF8\uC220\uAD00\uC740
    \uC9C0\uB09C 28\uC77C \uAE30\uD68D\uC804 \u300A\uAE30\uC5B5\uC758 \uD658\uC0DD\u300B\uC744
    \uAC1C\uB9C9\uD558\uACE0, MINd Cloud\uC5D0 \uBCF4\uAD00\uB41C \uAE30\uC5B5 \uB370\uC774\uD130\uB97C
    \uD65C\uC6A9\uD55C \uC124\uCE58 \uC791\uD488 14\uC810\uC744 \uACF5\uAC1C\uD588\uB2E4.\r\n\r\n\uC774\uBC88
    \uC804\uC2DC\uB294 \uACE0\uC778\uC774 \uC0DD\uC804 \uB0A8\uAE34 \uC2DC\uAC01
    \uAE30\uC5B5, \uC74C\uC131 \uC870\uAC01, \uC704\uCE58 \uAE30\uB85D, Dlog \uB300\uD654
    \uC77C\uBD80\uB97C \uBC14\uD0D5\uC73C\uB85C \uD2B9\uC815 \uC2DC\uAE30\uC758 \uACF5\uAC04\uC744
    \uC7AC\uAD6C\uC131\uD558\uB294 \uBC29\uC2DD\uC73C\uB85C \uC81C\uC791\uB410\uB2E4.
    \uAD00\uB78C\uAC1D\uC740 \uC804\uC2DC\uC7A5 \uC548\uC5D0\uC11C \uACE0\uC778\uC758
    \uBC29, \uCD9C\uADFC\uAE38, \uB9C8\uC9C0\uB9C9 \uAC00\uC871 \uC2DD\uC0AC \uC7A5\uBA74
    \uB4F1\uC744 \uBAB0\uC785\uD615 \uD640\uB85C\uADF8\uB7A8\uC73C\uB85C \uCCB4\uD5D8\uD560
    \uC218 \uC788\uB2E4.\r\n\r\n\uBBF8\uC220\uAD00 \uCE21\uC740 \u201C\uAE30\uC5B5\uC740
    \uB354 \uC774\uC0C1 \uAC1C\uC778\uC758 \uBA38\uB9BF\uC18D\uC5D0\uB9CC \uB0A8\uB294
    \uC790\uB8CC\uAC00 \uC544\uB2C8\uB2E4\u201D\uB77C\uBA70 \u201C\uC774\uBC88 \uC804\uC2DC\uB294
    \uC800\uC7A5\uB41C \uAE30\uC5B5\uC774 \uC608\uC220\uC801 \uAE30\uB85D\uC73C\uB85C
    \uC804\uD658\uB418\uB294 \uACFC\uC815\uC744 \uBCF4\uC5EC\uC900\uB2E4\u201D\uACE0
    \uC124\uBA85\uD588\uB2E4.\r\n\r\n\uC804\uC2DC\uC5D0 \uCC38\uC5EC\uD55C \uD55C
    \uC720\uC871\uC740 \u201C\uC544\uBC84\uC9C0\uAC00 \uC549\uC544 \uC788\uB358 \uC2DD\uD0C1\uC758
    \uAC01\uB3C4\uAE4C\uC9C0 \uADF8\uB300\uB85C \uBCF5\uC6D0\uB3FC \uB180\uB790\uB2E4\u201D\uBA70
    \u201C\uC2AC\uD504\uB2E4\uAE30\uBCF4\uB2E4 \uB2E4\uC2DC \uD655\uC778\uBC1B\uB294
    \uB290\uB08C\uC774\uC5C8\uB2E4\u201D\uACE0 \uB9D0\uD588\uB2E4.\r\n\r\n\uC77C\uBD80
