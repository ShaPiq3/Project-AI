  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "AI \uACBD\uB85C \uC548\uB0B4 \uAE30\uB2A5\uC744 \uB048 \uCC44 \uC5EC\uD589\uC744
    \uB5A0\uB0AC\uB358 20\uB300 \uB0A8\uB140\uAC00 \uC2E4\uC885 \uC77C\uC8FC\uC77C
    \uB9CC\uC5D0 \uC0B0\uC18D \uC778\uADFC \uB3C4\uB85C\uC5D0\uC11C \uAD6C\uC870\uB410\uB2E4.\r\n\r\n\uC778\uC81C\uACBD\uCC30\uC11C\uC640
    \uC778\uC81C\uC18C\uBC29\uC11C\uC5D0 \uB530\uB974\uBA74 \uC9C0\uB09C 12\uC77C
    \uC624\uD6C4 4\uC2DC\uCBE4 \uAC15\uC6D0\uB3D9\uBD80\uAD8C \uC57C\uC0B0 \uC778\uADFC
    \uC784\uB3C4\uC5D0\uC11C \uAE40\uBAA8 \uC528(22)\uC640 \uC774\uBAA8 \uC528(21)\uAC00
    \uBC1C\uACAC\uB410\uB2E4. \uB450 \uC0AC\uB78C\uC740 \uBC1C\uACAC \uB2F9\uC2DC
    \uD0C8\uC9C4 \uC99D\uC138\uB97C \uBCF4\uC600\uC73C\uB098 \uC0DD\uBA85\uC5D0\uB294
    \uC9C0\uC7A5\uC774 \uC5C6\uB294 \uAC83\uC73C\uB85C \uC54C\uB824\uC84C\uB2E4.\r\n\r\n\uAE40
    \uC528\uC640 \uC774 \uC528\uB294 \uB3D9\uBA85\uB300\uD559\uAD50 \uB3D9\uAE30\uB85C,
    \uC9C0\uB09C 5\uC77C \uC9C0\uC778\uB4E4\uC5D0\uAC8C \u201C\uC5EC\uD589\uC744
    \uB2E4\uB140\uC624\uACA0\uB2E4\u201D\uACE0 \uB9D0\uD55C \uB4A4 \uC5F0\uB77D\uC774
    \uB04A\uACBC\uB2E4. \uB450 \uC0AC\uB78C\uC774 \uB9C8\uC9C0\uB9C9\uC73C\uB85C
    \uBCF4\uB0B8 \uBA54\uC2DC\uC9C0\uC5D0\uB294 \u201CAI \uACBD\uB85C \uC548\uB0B4\uB97C
    \uAEBC\uB480\uB2E4\u201D, \u201C\uC9C1\uC811 \uCC3E\uC544\uAC00\uBA74 \uB420
    \uAC83 \uAC19\uB2E4\u201D, \u201C\uAE38\uC774 \uC0DD\uAC01\uBCF4\uB2E4 \uBCF5\uC7A1\uD558\uB2E4\u201D\uB294
    \uB0B4\uC6A9\uC774 \uB2F4\uAE34 \uAC83\uC73C\uB85C \uC804\uD574\uC84C\uB2E4.\r\n\r\n\uB3D9\uAE30\uB4E4\uC740
    \uB450 \uC0AC\uB78C\uC774 \u201C\uBD80\uBAA8\uB2D8\uAED8\uB294 \uC54C\uB9AC\uC9C0
    \uB9D0\uC544\uB2EC\uB77C\u201D\uACE0 \uD588\uAE30 \uB54C\uBB38\uC5D0 \uCC98\uC74C\uC5D0\uB294
    \uC2E0\uACE0\uB97C \uB9DD\uC124\uC600\uC73C\uB098, \uB2E4\uC74C \uB0A0\uAE4C\uC9C0
    \uC5F0\uB77D\uC774 \uB2FF\uC9C0 \uC54A\uC790 \uACBD\uCC30\uC5D0 \uC2E4\uC885
    \uC2E0\uACE0\uB97C \uD588\uB2E4.\r\n\r\n\uACBD\uCC30\uC740 \uB450 \uC0AC\uB78C\uC758
    \uB9C8\uC9C0\uB9C9 \uD734\uB300\uC804\uD654 \uC704\uCE58\uAC12\uACFC \uC778\uADFC
    CCTV, \uCC28\uB7C9 \uC774\uB3D9 \uACBD\uB85C \uB4F1\uC744 \uD1A0\uB300\uB85C
    \uC218\uC0C9\uC744 \uBC8C\uC600\uB2E4. \uD574\uB2F9 \uC9C0\uC5ED\uC740 \uC0B0\uAE38\uACFC
    \uC784\uB3C4\uAC00 \uC5EC\uB7EC \uAC08\uB798\uB85C \uC774\uC5B4\uC838 \uC788\uC5B4
    \uC218\uC0C9\uC5D0 \uC5B4\uB824\uC6C0\uC774 \uC788\uC5C8\uB358 \uAC83\uC73C\uB85C
    \uC804\uD574\uC84C\uB2E4.\r\n\r\n\uB450 \uC0AC\uB78C\uC758 \uCC28\uB7C9\uC740
    \uBE44\uD3EC\uC7A5\uB3C4\uB85C \uAC00\uC7A5\uC790\uB9AC\uC5D0\uC11C \uBC1C\uACAC\uB410\uB2E4.
    \uCC28\uB7C9 \uBC14\uD034 \uC77C\uBD80\uAC00 \uC9C4\uD759\uC5D0 \uBE60\uC838
    \uC788\uC5C8\uACE0, \uB0B4\uBD80\uC5D0\uC11C\uB294 \uBC29\uC804\uB41C \uD734\uB300\uC804\uD654\uC640
    \uBE48 \uC0DD\uC218\uBCD1, \uAC04\uD3B8\uC2DD \uD3EC\uC7A5\uC9C0 \uB4F1\uC774
    \uD655\uC778\uB410\uB2E4.\r\n\r\n\uACBD\uCC30\uC740 \uB450 \uC0AC\uB78C\uC774
    \uC704\uCE58 \uAE30\uB85D\uC744 \uB0A8\uAE30\uC9C0 \uC54A\uAE30 \uC704\uD574
    AI \uACBD\uB85C \uC548\uB0B4\uC640 \uBCF4\uD638\uC790 \uACF5\uC720 \uAE30\uB2A5\uC744
    \uB048 \uB4A4 \uC0B0\uAC04 \uB3C4\uB85C\uB85C \uC9C4\uC785\uD588\uB2E4\uAC00
    \uAE38\uC744 \uC783\uC740 \uAC83\uC73C\uB85C \uBCF4\uACE0 \uC788\uB2E4.\r\n\r\n\uAD6C\uC870
    \uC9C1\uD6C4 \uB450 \uC0AC\uB78C\uC740 \u201C\uCC98\uC74C\uC5D0\uB294 \uAE08\uBC29
    \uB098\uAC08 \uC218 \uC788\uC744 \uC904 \uC54C\uC558\uB2E4\u201D\uACE0 \uB9D0\uD55C
    \uAC83\uC73C\uB85C \uC54C\uB824\uC84C\uB2E4. \uD604\uC7AC \uB450 \uC0AC\uB78C\uC740
    \uC778\uADFC \uBCD1\uC6D0\uC73C\uB85C \uC774\uC1A1\uB3FC \uCE58\uB8CC\uB97C \uBC1B\uACE0
    \uC788\uB2E4.\r\n\r\n\uACBD\uCC30 \uAD00\uACC4\uC790\uB294 \u201C\uB0AF\uC120
    \uC9C0\uC5ED, \uD2B9\uD788 \uC0B0\uAC04 \uC9C0\uC5ED\uC744 \uC774\uB3D9\uD560
    \uB54C\uB294 AI \uACBD\uB85C \uC548\uB0B4\uC640 \uC704\uCE58 \uACF5\uC720 \uAE30\uB2A5\uC744
    \uC720\uC9C0\uD574\uC57C \uD55C\uB2E4\u201D\uBA70 \u201C\uAC1C\uC778\uC801\uC778
    \uC774\uC720\uB85C \uC77C\uBD80 \uAE30\uB2A5\uC744 \uB044\uB354\uB77C\uB3C4 \uBE44\uC0C1
    \uC5F0\uB77D \uC218\uB2E8\uC740 \uBC18\uB4DC\uC2DC \uD655\uBCF4\uD574\uC57C \uD55C\uB2E4\u201D\uACE0
    \uB2F9\uBD80\uD588\uB2E4.\r\n"
  m_isRightToLeft: 0
