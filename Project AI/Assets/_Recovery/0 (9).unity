      m_Calls: []
  m_text: "\uAC10\uC815 \uC131\uC0AC\uC728\uC774 10%\uB300\uC5D0 \uADF8\uCE5C \uC0C1\uB300\uC640
    \uACB0\uD63C\uC744 \uCD94\uC9C4\uD55C \uB0A8\uC131\uC758 \uC0AC\uB840\uAC00 \uC54C\uB824\uC84C\uB2E4.\r\n\r\n\uC9C0\uB09C
    16\uC77C\uACB0\uD63C \uB9E4\uCE6D \uC560\uD50C\uB9AC\uCF00\uC774\uC158 \uD398\uC5B4\uB9C1\uD06C(PairLink)
    \uD68C\uC6D0 A\uC528\uB294 \uC5EC\uC131 \uD68C\uC6D0 B\uC528\uC640\uC758 \uAC10\uC815
    \uC131\uC0AC\uC728\uC774 10% \uB0A8\uC9D3\uC73C\uB85C \uCE21\uC815\uB410\uC74C\uC5D0\uB3C4
    \uBCC4\uB3C4\uB85C \uC5F0\uB77D\uD574 \uB9CC\uB0A8\uC744 \uC774\uC5B4\uAC14\uB2E4.\r\n\r\nA\uC528\uB294
    B\uC528\uAC00 \u201C\uBCF8\uC778\uC5D0\uAC8C \uC798 \uB9DE\uC744 \uAC83 \uAC19\uB2E4\u201D\uB294
    \uC774\uC720\uB85C \uC560\uD50C\uB9AC\uCF00\uC774\uC158\uC758 \uCD94\uCC9C \uACB0\uACFC\uB97C
    \uB530\uB974\uC9C0 \uC54A\uC740 \uAC83\uC73C\uB85C \uC804\uD574\uC84C\uB2E4.
    \uC774\uD6C4 \uB450 \uC0AC\uB78C\uC740 \uC571\uC744 \uD0C8\uD1F4\uD558\uACE0
    \uAC1C\uBCC4\uC801\uC73C\uB85C \uAD50\uC81C\uB97C \uC774\uC5B4\uAC14\uB2E4.\r\n\r\n\uC774\uB4E4\uC740
    \uC591\uAC00 \uBD80\uBAA8\uC5D0\uAC8C \uC11C\uB85C\uB97C \uC18C\uAC1C\uD558\uB294
    \uACFC\uC815\uC5D0\uC11C \uC2E4\uC81C \uAC10\uC815 \uC131\uC0AC\uC728\uC744 \uC228\uAE30\uACE0,
    \uC218\uCE58\uAC00 \uB192\uAC8C \uD45C\uC2DC\uB41C \uD654\uBA74\uC744 \uC870\uC791\uD574
    \uC804\uB2EC\uD55C \uAC83\uC73C\uB85C \uC54C\uB824\uC84C\uB2E4.\r\n\r\n\uC591\uAC00
    \uBD80\uBAA8\uB294 \uD574\uB2F9 \uC790\uB8CC\uB97C \uBC14\uD0D5\uC73C\uB85C \uB9CC\uB0A8\uC744
    \uD5C8\uB77D\uD588\uC73C\uB098, \uC774\uD6C4 \uC2E4\uC81C \uAE30\uB85D\uACFC
    \uB2E4\uB978 \uC0AC\uC2E4\uC774 \uD655\uC778\uB418\uBA70 \uBB38\uC81C\uAC00 \uBD88\uAC70\uC84C\uB2E4.\r\n\r\nA\uC528
    \uAC00\uC871\uC740 \u201C\uAC10\uC815 \uC131\uC0AC\uC728\uC774 \uB0AE\uC740 \uAD00\uACC4\uC778
    \uC904 \uC54C\uC558\uB2E4\uBA74 \uB9CC\uB0A8\uC744 \uD5C8\uB77D\uD558\uAE30 \uC5B4\uB824\uC6E0\uC744
    \uAC83\u201D\uC774\uB77C\uBA70 \u201C\uACB0\uD63C\uCC98\uB7FC \uC911\uC694\uD55C
    \uD310\uB2E8\uC5D0\uC11C \uAC80\uC99D \uC218\uCE58\uB97C \uC228\uAE34 \uAC83\uC740
    \uBC1B\uC544\uB4E4\uC774\uAE30 \uC5B4\uB835\uB2E4\u201D\uACE0 \uBC1D\uD614\uB2E4.\r\n\r\n\uAD00\uACC4
    \uC804\uBB38\uAC00\uB4E4\uC740 \uAC10\uC815 \uC131\uC0AC\uC728\uC774 \uB0AE\uC740
