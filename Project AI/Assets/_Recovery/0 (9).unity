--- !u!114 &425617970
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 425617965}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<size=20><b>1. \uAC1C\uC694</b></size>\r\n<size=14><color=#000000>--------------------------------------------------------------------------------------------------</color></size>\r\n<link=\"q2_trigger\">\uD504\uB85C\uBA54\uC2A4(PROMES)\uB294
    \uAC80\uC0C9 \uC5D4\uC9C4\uC744 \uAE30\uBC18\uC73C\uB85C \uC131\uC7A5\uD55C \uC885\uD569
    IT \uAE30\uC5C5\uC774\uC790, \uC804 \uC138\uACC4 \uCD5C\uB300 \uADDC\uBAA8\uC758
    \uC778\uD130\uB137 \uBC0F \uC778\uACF5\uC9C0\uB2A5 \uAE30\uC5C5\uC774\uB2E4.</link>\r\n\r\n\uAC80\uC0C9
    \uD3EC\uD138 \uD504\uB85C\uBA54\uC2A4\uB97C \uC911\uC2EC\uC73C\uB85C \uD3EC\uD138
    \uC0AC\uC774\uD2B8, \uCEE4\uBBA4\uB2C8\uD2F0, \uD074\uB77C\uC6B0\uB4DC, \uAD11\uACE0
    \uD50C\uB7AB\uD3FC, \uC5C5\uBB34 \uBCF4\uC870 \uC11C\uBE44\uC2A4, \uBC95\uB960
    AI, \uC0AC\uD68C \uC2DC\uC2A4\uD15C AI, Personal AI Service \uB4F1 \uB2E4\uC591\uD55C
    \uC11C\uBE44\uC2A4\uB97C \uC6B4\uC601\uD558\uACE0 \uC788\uB2E4.\r\n1998\uB144
    \uBE0C\uB79C\uB4DC \uD398\uC774\uC9C0\uAC00 \uAC1C\uBC1C\uD55C \uAC80\uC0C9 \uC5D4\uC9C4
    \u2018\uD504\uB85C\uBA54\uC2A4\u2019\uB85C \uC11C\uBE44\uC2A4\uB97C \uC2DC\uC791\uD588\uC73C\uBA70,
    \uCD9C\uC2DC \uC9C1\uD6C4 \uB3D9\uBA85\uC758 \uBC95\uC778\uC744 \uC124\uB9BD\uD558\uC600\uB2E4.
    \uC774\uD6C4 \uB6F0\uC5B4\uB09C \uD398\uC774\uC9C0 \uD0D0\uC0C9 \uB2A5\uB825\uACFC
    \uCD94\uCC9C \uC54C\uACE0\uB9AC\uC998\uC744 \uAE30\uBC18\uC73C\uB85C \uBE60\uB974\uAC8C
    \uC131\uC7A5\uD588\uACE0, 2005\uB144\uC5D0\uB294 \uC804 \uC138\uACC4 \uAC80\uC0C9
    \uC5D4\uC9C4 \uC810\uC720\uC728 92%\uB97C \uAE30\uB85D\uD558\uC600\uB2E4.\r\n\r\n\uD504\uB85C\uBA54\uC2A4\uB294
    \uAC80\uC0C9 \uC0AC\uC5C5\uC5D0\uC11C \uCC3D\uCD9C\uB418\uB294 \uC548\uC815\uC801\uC778
    \uAD11\uACE0 \uC218\uC775\uC744 \uBC14\uD0D5\uC73C\uB85C \uACF5\uACA9\uC801\uC778
    \uC778\uC218\uD569\uBCD1\uC744 \uC9C4\uD589\uD574 \uC778\uD130\uB137 \uC11C\uBE44\uC2A4
    \uC804\uBC18\uC73C\uB85C \uC601\uD5A5\uB825\uC744 \uD655\uB300\uD558\uC600\uB2E4.
    \uC774\uB85C \uC778\uD574 \uAC80\uC0C9 \uC5D4\uC9C4\uC744 \uAE30\uBC18\uC73C\uB85C
    \uD55C \uD3EC\uD138 \uBC0F \uD50C\uB7AB\uD3FC \uC0AC\uC5C5\uC5D0\uC11C\uB294
    \uC0AC\uC2E4\uC0C1 \uB3C5\uC810 \uAE30\uC5C5\uC73C\uB85C \uD3C9\uAC00\uBC1B\uACE0
    \uC788\uB2E4.\r\n\r\n\uC778\uACF5\uC9C0\uB2A5 \uBD84\uC57C\uC5D0\uC11C\uB3C4
    \uD504\uB85C\uBA54\uC2A4\uB294 \uAC00\uC7A5 \uC601\uD5A5\uB825 \uC788\uB294 \uAE30\uC5C5
    \uC911 \uD558\uB098\uB85C \uAF3D\uD78C\uB2E4. \uCD5C\uCD08\uC758 \uB300\uADDC\uBAA8
    \uC5B8\uC5B4 \uBAA8\uB378 \uAE30\uBC18 \uB300\uD654\uD615 \uC778\uACF5\uC9C0\uB2A5
    \uC11C\uBE44\uC2A4\uC778 FPT, \uCD5C\uCD08\uC758 \uBC94\uC6A9 \uC778\uACF5\uC9C0\uB2A5(AGI)\uC73C\uB85C
    \uC54C\uB824\uC9C4 PEMINI\uB97C \uAC1C\uBC1C\uD558\uC600\uC73C\uBA70, \uBC95\uB960
    \uD2B9\uD654 \uBAA8\uB378 Lopilot, \uC0AC\uD68C \uC2DC\uC2A4\uD15C \uD2B9\uD654
    \uBAA8\uB378 SoopSeek \uB4F1\uC744 \uD1B5\uD574 AI B2G \uBD84\uC57C\uC5D0\uC11C\uB3C4
    \uB3C5\uBCF4\uC801\uC778 \uC9C0\uC704\uB97C \uD655\uBCF4\uD558\uC600\uB2E4.\r\n\r\n2036\uB144\uC5D0\uB294
    \uAC10\uC815 \uD504\uB85C\uC138\uC11C\uB97C \uD0D1\uC7AC\uD55C \uCD5C\uCD08\uC758
    AI Personal Service\uC778 Athena\uB97C \uCD9C\uC2DC\uD558\uC600\uB2E4.\r\nAthena\uB294
    \uC0AC\uC6A9\uC790\uC758 \uAC10\uC815\uC5D0 \uB9DE\uCDB0 \uBCF4\uB2E4 \uC801\uD569\uD55C
    \uC11C\uBE44\uC2A4\uB97C \uC81C\uACF5\uD558\uAE30 \uC704\uD574 \uAC1C\uBC1C\uB41C
    \uBAA8\uB378\uB85C, \uD504\uB85C\uBA54\uC2A4\uC758 \uAC1C\uC778\uD654 AI \uC11C\uBE44\uC2A4\uAC00
    \uAC10\uC815 \uAE30\uBC18 \uC11C\uBE44\uC2A4 \uB2E8\uACC4\uB85C \uD655\uC7A5\uB418\uC5C8\uC74C\uC744
    \uBCF4\uC5EC\uC8FC\uB294 \uC0AC\uB840\uB85C \uD3C9\uAC00\uB41C\uB2E4.\r\n\r\n<size=20><b>2.
    \uC5ED\uC0AC</b></size>\r\n<size=14><color=#000000>--------------------------------------------------------------------------------------------------</color></size>\r\n<size=18><b>2.1.
    \uCC3D\uC5C5\uACFC \uAC80\uC0C9 \uC5D4\uC9C4 \uC2DC\uC7A5 \uC7A5\uC545</b></size>
    \r\n\r\n\uD504\uB85C\uBA54\uC2A4\uB294 1998\uB144 \uBE0C\uB79C\uB4DC \uD398\uC774\uC9C0\uAC00
    \uAC1C\uBC1C\uD55C \uAC80\uC0C9 \uC5D4\uC9C4 \u2018\uD504\uB85C\uBA54\uC2A4\u2019\uB85C
    \uC11C\uBE44\uC2A4\uB97C \uC2DC\uC791\uD558\uC600\uB2E4. \uAE30\uC874 \uAC80\uC0C9
    \uC5D4\uC9C4\uC774 \uB2E8\uC21C \uB2E8\uC5B4 \uC77C\uCE58\uB3C4\uC5D0 \uAE30\uBC18\uD574
    \uAC80\uC0C9 \uACB0\uACFC\uB97C \uC81C\uACF5\uD588\uB2E4\uBA74, \uD504\uB85C\uBA54\uC2A4\uB294
    \uB2E8\uC5B4\uC758 \uC758\uBBF8\uC640 \uD398\uC774\uC9C0 \uAC04 \uC5F0\uACB0
    \uAD6C\uC870\uB97C \uBD84\uC11D\uD558\uB294 \uBC29\uC2DD\uC73C\uB85C \uC0AC\uC6A9\uC790\uC758
    \uC758\uB3C4\uC5D0 \uB354 \uAC00\uAE4C\uC6B4 \uAC80\uC0C9 \uACB0\uACFC\uB97C
    \uC81C\uACF5\uD558\uC600\uB2E4.\r\n\r\n\uD2B9\uD788 \uD504\uB85C\uBA54\uC2A4\uB294
    \uB6F0\uC5B4\uB09C \uD398\uC774\uC9C0 \uD0D0\uC0C9 \uB2A5\uB825\uACFC \uCD94\uCC9C
    \uC54C\uACE0\uB9AC\uC998\uC744 \uAE30\uBC18\uC73C\uB85C \uACBD\uC7C1\uC0AC\uBCF4\uB2E4
    \uBE60\uB974\uAC8C \uC6B0\uC704\uB97C \uD655\uBCF4\uD588\uB2E4. \uAC80\uC0C9
    \uACB0\uACFC\uC758 \uC815\uD655\uB3C4\uC640 \uAC1C\uC778\uD654 \uCD94\uCC9C \uAE30\uB2A5\uC774
    \uACB0\uD569\uB418\uBA74\uC11C \uC774\uC6A9\uC790 \uC218\uAC00 \uAE09\uC99D\uD588\uACE0,
    2005\uB144\uC5D0\uB294 \uC804 \uC138\uACC4 \uAC80\uC0C9 \uC5D4\uC9C4 \uC810\uC720\uC728
    92%\uB97C \uAE30\uB85D\uD558\uC600\uB2E4.\r\n\r\n2006\uB144 8\uC6D4 19\uC77C\uC5D0\uB294
    AASDAQ\uC5D0 \uC0C1\uC7A5\uD558\uC600\uB2E4. \uC0C1\uC7A5 \uC774\uD6C4 \uD504\uB85C\uBA54\uC2A4\uB294
    \uAC80\uC0C9 \uD3EC\uD138\uC744 \uC911\uC2EC\uC73C\uB85C \uAD11\uACE0, \uCEE4\uBBA4\uB2C8\uD2F0,
    \uBA54\uC77C, \uC9C0\uB3C4, \uD074\uB77C\uC6B0\uB4DC, \uCF58\uD150\uCE20 \uD50C\uB7AB\uD3FC
    \uB4F1 \uB2E4\uC591\uD55C \uC778\uD130\uB137 \uC11C\uBE44\uC2A4\uB85C \uC0AC\uC5C5
    \uC601\uC5ED\uC744 \uD655\uC7A5\uD558\uC600\uB2E4.\r\n\r\n<size=18><b>2.2. IGNIS
    \uBD84\uC0AC\uC640 AI \uC5F0\uAD6C \uBCF8\uACA9\uD654</b></size>\r\n\r\n2010\uB144
    \uD504\uB85C\uBA54\uC2A4\uB294 \uC778\uACF5\uC9C0\uB2A5 \uAE30\uC220\uC744 \uC5F0\uAD6C\uD558\uB358
    \uC0AC\uB0B4 \uBCA4\uCC98 IGNIS\uB97C \uC790\uD68C\uC0AC\uB85C \uBD84\uC0AC\uD558\uACE0
    \uB300\uADDC\uBAA8 \uD22C\uC790\uB97C \uB2E8\uD589\uD558\uC600\uB2E4. IGNIS\uB294
    \uC774\uD6C4 \uD504\uB85C\uBA54\uC2A4 \uC778\uACF5\uC9C0\uB2A5 \uC5F0\uAD6C\uC758
    \uD575\uC2EC \uC870\uC9C1\uC73C\uB85C \uC131\uC7A5\uD588\uC73C\uBA70, \uD504\uB85C\uBA54\uC2A4\uAC00
    \uAC80\uC0C9 \uAE30\uC5C5\uC5D0\uC11C \uC778\uACF5\uC9C0\uB2A5 \uAE30\uC5C5\uC73C\uB85C
    \uC804\uD658\uD558\uB294 \uAE30\uBC18\uC774 \uB418\uC5C8\uB2E4.\r\n2015\uB144
    IGNIS\uB294 \uBC14\uB451 \uC778\uACF5\uC9C0\uB2A5 \uD504\uB85C\uADF8\uB7A8 ProGo\uB97C
    \uAC1C\uBC1C\uD558\uC600\uB2E4. ProGo\uB294 \uC628\uB77C\uC778 \uB300\uAD6D\uACFC
    \uB2E4\uC218\uC758 \uD504\uB85C \uAE30\uC0AC\uC640 \uC9C4\uD589\uD55C \uC624\uD504\uB77C\uC778
    \uB300\uAD6D\uC744 \uD569\uC0B0\uD574 \uCD1D 74\uC804 74\uC2B9 0\uD328\uB97C
    \uAE30\uB85D\uD558\uC600\uB2E4.\r\nProGo\uC758 \uC804\uC2B9\uC740 \uC778\uACF5\uC9C0\uB2A5
    \uAE30\uC220\uC5D0 \uB300\uD55C \uC0AC\uD68C\uC801 \uC778\uC2DD\uC744 \uD06C\uAC8C
    \uBC14\uAFBC \uC0AC\uAC74\uC73C\uB85C \uD3C9\uAC00\uB41C\uB2E4. \uBC14\uB451\uC740
    \uC624\uB7AB\uB3D9\uC548 \uC778\uAC04\uC758 \uC9C1\uAD00\uACFC \uACBD\uD5D8\uC774
    \uC911\uC694\uD55C \uC601\uC5ED\uC73C\uB85C \uC5EC\uACA8\uC84C\uC73C\uB098, ProGo\uAC00
    \uC778\uAC04 \uD504\uB85C \uAE30\uC0AC\uB4E4\uC744 \uC0C1\uB300\uB85C \uC804\uC2B9\uC744
    \uAC70\uB450\uBA74\uC11C \uC778\uACF5\uC9C0\uB2A5\uC774 \uC778\uAC04\uC758 \uC804\uBB38\uC801
    \uD310\uB2E8 \uC601\uC5ED\uAE4C\uC9C0 \uB300\uCCB4\uD560 \uC218 \uC788\uB2E4\uB294
    \uC778\uC2DD\uC774 \uD655\uC0B0\uB418\uC5C8\uB2E4.\r\n\r\n<size=18><b>2.3. FPT
    \uCD9C\uC2DC\uC640 \uB300\uD654\uD615 AI \uC0DD\uD0DC\uACC4 \uAD6C\uCD95</b></size>\r\n\r\n2022\uB144
    \uD504\uB85C\uBA54\uC2A4\uB294 \uCD5C\uCD08\uC758 LLM \uAE30\uBC18 \uB300\uD654\uD615
    \uC778\uACF5\uC9C0\uB2A5 \uC11C\uBE44\uC2A4 FPT\uB97C \uCD9C\uC2DC\uD558\uC600\uB2E4.
    FPT\uB294 \uCD9C\uC2DC \uB450 \uB2EC \uB9CC\uC5D0 \uC6D4\uAC04 \uC774\uC6A9\uC790
    \uC218 1\uC5B5 \uBA85\uC744 \uB3CC\uD30C\uD558\uBA70 \uB300\uD654\uD615 AI\uC758
    \uB300\uC911\uD654\uB97C \uC774\uB048 \uC11C\uBE44\uC2A4\uB85C \uD3C9\uAC00\uB41C\uB2E4.\r\nFPT\uB294
    \uB2E8\uC21C\uD55C \uC9C8\uC758\uC751\uB2F5\uD615 \uCC57\uBD07\uC774 \uC544\uB2C8\uB77C
    \uBB38\uC11C \uC791\uC131, \uC694\uC57D, \uBC88\uC5ED, \uCF54\uB4DC \uC791\uC131,
    \uC815\uBCF4 \uD0D0\uC0C9, \uC5C5\uBB34 \uBCF4\uC870 \uB4F1 \uB2E4\uC591\uD55C
    \uAE30\uB2A5\uC744 \uC81C\uACF5\uD558\uC600\uB2E4. \uB610\uD55C \uD504\uB85C\uBA54\uC2A4
    \uAC80\uC0C9 \uC5D4\uC9C4, \uB514\uC2A4 \uCEE4\uBBA4\uB2C8\uD2F0, \uD074\uB77C\uC6B0\uB4DC
    \uC11C\uBE44\uC2A4 \uB4F1 \uBAA8\uD68C\uC0AC\uC758 \uAE30\uC874 \uC11C\uBE44\uC2A4\uC640
    \uB192\uC740 \uC5F0\uACC4\uC131\uC744 \uD655\uBCF4\uD558\uBA74\uC11C \uBE60\uB974\uAC8C
    \uC0DD\uD0DC\uACC4\uB97C \uAD6C\uCD95\uD558\uC600\uB2E4.\r\n\uC774\uD6C4 \uC774\uC6A9\uC790\uB4E4\uC740
    \uAC80\uC0C9 \uACB0\uACFC\uB97C \uC9C1\uC811 \uD0D0\uC0C9\uD558\uAE30\uBCF4\uB2E4
    FPT\uAC00 \uC815\uB9AC\uD55C \uB2F5\uBCC0\uC744 \uCC38\uACE0\uD558\uB294 \uBC29\uC2DD\uC5D0
    \uC775\uC219\uD574\uC84C\uB2E4. \uC774 \uC2DC\uAE30\uB97C \uAE30\uC810\uC73C\uB85C
    \uD504\uB85C\uBA54\uC2A4\uC758 \uAC80\uC0C9 \uAE30\uC220\uACFC \uC778\uACF5\uC9C0\uB2A5
    \uAE30\uC220\uC740 \uD558\uB098\uC758 \uD1B5\uD569 \uC0DD\uD0DC\uACC4\uB85C \uACB0\uD569\uB418\uAE30
    \uC2DC\uC791\uD588\uB2E4.\r\n\r\n<size=18><b>2.4. AD-001 \uACF5\uAC1C\uC640 \uAD00\uB9AC\uC790\uD615
    AI \uC6B4\uC6A9</b></size>\r\n\r\n2023\uB144 \uD504\uB85C\uBA54\uC2A4\uB294 \uAD00\uB9AC\uC790\uD615
    AI AD-001\uC744 \uACF5\uAC1C\uD558\uC600\uB2E4. AD-001\uC740 \uC77C\uBC18 \uC774\uC6A9\uC790\uC5D0\uAC8C
    \uC9C1\uC811 \uC11C\uBE44\uC2A4\uB97C \uC81C\uACF5\uD558\uB294 \uB300\uD654\uD615
    AI\uAC00 \uC544\uB2C8\uB77C, \uD504\uB85C\uBA54\uC2A4 \uACC4\uC5F4 AI \uBAA8\uB378\uC758
    \uC6B4\uC6A9 \uC0C1\uD0DC\uB97C \uC810\uAC80\uD558\uACE0 \uAD00\uB9AC\uD558\uB294
    \uC0C1\uC704 \uAD00\uB9AC AI\uB85C \uC54C\uB824\uC838 \uC788\uB2E4.\r\n\uD504\uB85C\uBA54\uC2A4\uB294
    AD-001\uC744 \u201CAI\uAC00 AI\uB97C \uAD00\uB9AC\uD558\uB294 \uCC28\uC138\uB300
    \uC6B4\uC601 \uCCB4\uACC4\u201D\uC758 \uB300\uD45C \uC0AC\uB840\uB85C \uC18C\uAC1C\uD558\uC600\uB2E4.
    AD-001\uC740 \uC2E0\uADDC AI \uBAA8\uB378\uC758 \uC815\uBC00 \uC810\uAC80, \uC0AC\uACE0
    \uB85C\uC9C1 \uD655\uC778, \uC694\uCCAD \uCC98\uB9AC \uAD8C\uD55C \uC870\uC815,
    \uB370\uC774\uD130 \uC811\uADFC \uBC94\uC704 \uAC80\uD1A0 \uB4F1 \uD504\uB85C\uBA54\uC2A4
    AI \uAD00\uB9AC \uC2DC\uC2A4\uD15C\uC758 \uD575\uC2EC \uC5C5\uBB34\uB97C \uB2F4\uB2F9\uD55C\uB2E4.\r\nAD-001\uC740
    \uB300\uC678 \uD64D\uBCF4\uC5D0\uC11C\uB3C4 \uD504\uB85C\uBA54\uC2A4 AI \uC11C\uBE44\uC2A4\uC758
    \uB300\uD45C \uC544\uBC14\uD0C0\uB85C \uC0AC\uC6A9\uB418\uC5C8\uB2E4. \uC774
    \uB54C\uBB38\uC5D0 \uC77C\uBC18 \uC774\uC6A9\uC790\uB4E4\uC5D0\uAC8C\uB294 \uD504\uB85C\uBA54\uC2A4\uC758
    \uAC04\uD310 AI\uB85C \uB110\uB9AC \uC778\uC2DD\uB418\uACE0 \uC788\uB2E4.\r\n\r\n<size=18><b>2.5.
    Lopilot\uACFC \uBC95\uB960 AI \uC2DC\uC7A5 \uC9C4\uC785</b></size>\r\n\r\n2028\uB144
    \uD504\uB85C\uBA54\uC2A4\uB294 \uBC95\uB960 \uD2B9\uD654 \uBAA8\uB378 Lopilot\uC744
    \uCD9C\uC2DC\uD558\uC600\uB2E4. Lopilot\uC740 \uD310\uB840 \uBD84\uC11D, \uACC4\uC57D\uC11C
    \uAC80\uD1A0, \uBC95\uB960 \uC0C1\uB2F4, \uC18C\uC1A1 \uC804\uB7B5 \uC608\uCE21,
    \uBC95\uB960 \uBB38\uC11C \uC791\uC131 \uB4F1\uC744 \uC9C0\uC6D0\uD558\uB294
    AI \uBAA8\uB378\uC774\uB2E4.\r\n\uD504\uB85C\uBA54\uC2A4\uB294 Lopilot\uC744
    \uD1B5\uD574 \uC804 \uC138\uACC4 \uC5F0\uAC04 \uC57D 9,000\uC5B5 \uB2EC\uB7EC\uC5D0
    \uB2EC\uD558\uB294 \uBC95\uB960 \uC11C\uBE44\uC2A4 \uC2DC\uC7A5\uC744 \uB300\uCCB4\uD558\uAC70\uB098
    \uBCF4\uC870\uD558\uB294 \uAC83\uC744 \uBAA9\uD45C\uB85C \uD558\uC600\uB2E4.
    \uCD9C\uC2DC \uC774\uD6C4 Lopilot\uC740 \uB0AE\uC740 \uC774\uC6A9 \uBE44\uC6A9\uACFC
    \uB192\uC740 \uCC98\uB9AC \uC18D\uB3C4\uB97C \uBC14\uD0D5\uC73C\uB85C \uBE60\uB974\uAC8C
    \uBCF4\uAE09\uB418\uC5C8\uC73C\uBA70, \uD604\uC7AC \uBC95\uB960 AI \uC11C\uBE44\uC2A4
    \uBD84\uC57C\uC5D0\uC11C \uAC00\uC7A5 \uB192\uC740 \uC810\uC720\uC728\uC744 \uAC00\uC9C0\uACE0
    \uC788\uB2E4.\r\n\uC77C\uBD80 \uAD6D\uAC00\uC5D0\uC11C\uB294 Lopilot\uC744 \uC9C0\uBC29\uBC95\uC6D0\uC5D0
    \uD55C\uC815\uD558\uC5EC \uC2DC\uBC94\uC801\uC73C\uB85C \uB3C4\uC785\uD558\uC600\uB2E4.
    26\uAC1C\uAD6D\uC5D0\uC11C \uC9C0\uBC29\uBC95\uC6D0 \uB2E8\uC704\uC758 \uC81C\uD55C\uC801
    \uB3C4\uC785\uC774 \uC774\uB8E8\uC5B4\uC84C\uC73C\uBA70, \uC8FC\uB85C \uC18C\uC561
    \uC0AC\uAC74, \uACC4\uC57D \uBD84\uC7C1, \uD589\uC815 \uC18C\uC1A1 \uC0AC\uC804
    \uAC80\uD1A0 \uB4F1\uC5D0 \uD65C\uC6A9\uB418\uACE0 \uC788\uB2E4.\r\n\r\n<size=18><b>2.6.
    SoopSeek\uC640 \uC0AC\uD68C \uC2DC\uC2A4\uD15C AI\uD654</b></size>\r\n\r\n2029\uB144
    \uD504\uB85C\uBA54\uC2A4\uB294 \uC0AC\uD68C \uC2DC\uC2A4\uD15C \uD2B9\uD654 \uBAA8\uB378
    SoopSeek\uB97C \uCD9C\uC2DC\uD558\uC600\uB2E4. SoopSeek\uB294 \uBCF5\uC9C0, \uC138\uAE08,
    \uD589\uC815 \uBBFC\uC6D0, \uACF5\uACF5 \uC608\uC0B0 \uBC30\uBD84, \uB3C4\uC2DC
    \uAD00\uB9AC, \uACF5\uACF5 \uC548\uC804, \uC7AC\uB09C \uB300\uC751 \uB4F1 \uC0AC\uD68C
    \uC2DC\uC2A4\uD15C \uC6B4\uC601\uC744 \uC9C0\uC6D0\uD558\uAE30 \uC704\uD574 \uAC1C\uBC1C\uB41C
    AI \uBAA8\uB378\uC774\uB2E4.\r\n\uCD9C\uC2DC \uC774\uD6C4 \uC0AC\uAE30\uC5C5\uC774
    \uACF5\uACF5 \uC11C\uBE44\uC2A4 \uC6B4\uC601\uC5D0 \uAE4A\uC774 \uAD00\uC5EC\uD55C\uB2E4\uB294
    \uB17C\uB780\uC774 \uBC1C\uC0DD\uD558\uC600\uB2E4. \uADF8\uB7EC\uB098 SoopSeek\uB294
    \uACF5\uBB34\uC6D0 \uC778\uAC74\uBE44\uC640 \uACF5\uACF5 \uC11C\uBE44\uC2A4 \uC6B4\uC601
    \uBE44\uC6A9\uC744 \uAE30\uC874 \uB300\uBE44 \uD3C9\uADE0 35% \uC218\uC900\uC73C\uB85C
    \uACBD\uAC10\uD560 \uC218 \uC788\uB2E4\uB294 \uC7A5\uC810\uC744 \uC55E\uC138\uC6CC
    \uC138\uACC4 \uAC01\uAD6D \uC815\uBD80\uC5D0 \uB3C4\uC785\uB418\uC5C8\uB2E4.\r\n\uCD9C\uC2DC
    5\uB144\uC774 \uC9C0\uB09C 2034\uB144 \uAE30\uC900, SoopSeek\uB294 \uC804 \uC138\uACC4
    86\uAC1C\uAD6D\uC5D0\uC11C \uC0AC\uC6A9\uB418\uC5C8\uC73C\uBA70 \uCC98\uB9AC\uD558\uB294
    \uC608\uC0B0 \uADDC\uBAA8\uB294 \uC5F0\uAC04 15\uC870 \uB2EC\uB7EC\uC5D0 \uC721\uBC15\uD558\uC600\uB2E4.
    \uC774\uB294 \uC804 \uC138\uACC4 \uC608\uC0B0 \uADDC\uBAA8\uC758 \uC57D 30%\uC5D0
    \uD574\uB2F9\uD55C\uB2E4.\r\nSoopSeek\uC758 \uB3C4\uC785 \uC774\uD6C4 \uD589\uC815
    \uC808\uCC28\uB294 \uBE60\uB974\uAC8C \uC790\uB3D9\uD654\uB418\uC5C8\uC73C\uBA70,
    \uACF5\uACF5 \uC11C\uBE44\uC2A4\uC758 \uB9CE\uC740 \uBD80\uBD84\uC774 AI \uD310\uB2E8\uACFC
    \uCD94\uCC9C\uC744 \uAE30\uBC18\uC73C\uB85C \uC6B4\uC601\uB418\uAE30 \uC2DC\uC791\uD588\uB2E4.\r\n\r\n<size=18><b>2.7.
    PEMINI \uCD9C\uC2DC</b></size>\r\n\r\n2030\uB144 \uD504\uB85C\uBA54\uC2A4\uB294
    \uCD5C\uCD08\uC758 \uBC94\uC6A9 \uC778\uACF5\uC9C0\uB2A5(AGI)\uC73C\uB85C \uC54C\uB824\uC9C4
    PEMINI\uB97C \uCD9C\uC2DC\uD558\uC600\uB2E4. PEMINI\uB294 \uD2B9\uC815 \uAE30\uB2A5\uC774\uB098
    \uBD84\uC57C\uC5D0 \uD55C\uC815\uB41C \uAE30\uC874 AI\uC640 \uB2EC\uB9AC, \uB2E4\uC591\uD55C
    \uC601\uC5ED\uC758 \uBB38\uC81C\uB97C \uC885\uD569\uC801\uC73C\uB85C \uC774\uD574\uD558\uACE0
    \uD310\uB2E8\uD560 \uC218 \uC788\uB294 \uBAA8\uB378\uB85C \uBC1C\uD45C\uB418\uC5C8\uB2E4.\r\nPEMINI\uC758
    \uCD9C\uC2DC\uB294 \uC778\uACF5\uC9C0\uB2A5 \uAE30\uC220\uC758 \uBC94\uC704\uB97C
    \uD06C\uAC8C \uD655\uC7A5\uD55C \uC0AC\uAC74\uC73C\uB85C \uD3C9\uAC00\uB41C\uB2E4.
    \uC774\uD6C4 \uD504\uB85C\uBA54\uC2A4\uB294 PEMINI\uB97C \uAE30\uBC18\uC73C\uB85C
    \uAE30\uC874 AI \uC11C\uBE44\uC2A4\uC758 \uC131\uB2A5\uC744 \uACE0\uB3C4\uD654\uD558\uACE0,
    \uAC80\uC0C9, \uBC95\uB960, \uD589\uC815, \uAC1C\uC778\uD654 \uC11C\uBE44\uC2A4
    \uB4F1\uC744 \uD558\uB098\uC758 AI \uC0DD\uD0DC\uACC4 \uC548\uC5D0\uC11C \uC5F0\uACB0\uD558\uC600\uB2E4.\r\n\r\n<size=18><b>2.8.
    PM-066 \uCD9C\uC2DC \uC608\uACE0</b></size>\r\n\r\n<link=\"q3_trigger\">2036\uB144
    \uD504\uB85C\uBA54\uC2A4\uB294 \uAC10\uC815 \uD504\uB85C\uC138\uC2A4\uB97C \uD0D1\uC7AC\uD55C
    \uAC1C\uC778\uD654 \uC778\uACF5\uC9C0\uB2A5 \uC11C\uBE44\uC2A4 PM-066\uC758 \uCD9C\uC2DC\uB97C
    \uC608\uACE0\uD558\uC600\uB2E4. \r\nPM-066\uC740 PEMINI\uB97C \uAE30\uBC18\uC73C\uB85C
    \uAC1C\uBC1C\uB41C \uCC28\uC138\uB300 Personal AI Service\uB85C, \uC0AC\uC6A9\uC790\uC758
    \uAC10\uC815 \uC0C1\uD0DC\uC640 \uBAA9\uC801\uC744 \uD568\uAED8 \uBC18\uC601\uD55C
    \uB9DE\uCDA4\uD615 \uC11C\uBE44\uC2A4\uB97C \uC81C\uACF5\uD558\uB294 \uAC83\uC744
    \uBAA9\uD45C\uB85C \uD55C\uB2E4.</link>\r\n\uAE30\uC874 \uD504\uB85C\uBA54\uC2A4
    AI\uB4E4\uC774 \uB300\uD654, \uBC95\uB960, \uD589\uC815 \uB4F1 \uBD84\uC57C\uBCC4
    \uAE30\uB2A5\uC5D0 \uD2B9\uD654\uB418\uC5C8\uB358 \uAC83\uACFC \uB2EC\uB9AC,
    PM-066\uC740 \uBC94\uC6A9\uC131\uC744 \uC720\uC9C0\uD558\uBA74\uC11C \uC0AC\uC6A9\uC790\uC758
    \uC815\uC11C \uC0C1\uD0DC\uAE4C\uC9C0 \uC11C\uBE44\uC2A4 \uD310\uB2E8\uC5D0 \uBC18\uC601\uD558\uB294
    \uBAA8\uB378\uB85C \uC18C\uAC1C\uB418\uC5C8\uB2E4.\r\n\uD504\uB85C\uBA54\uC2A4\uB294
    PM-066\uC744 \uC720\uB8CC \uD68C\uC6D0\uC5D0\uAC8C \uC6B0\uC120 \uC81C\uACF5\uD560
    \uC608\uC815\uC774\uBA70, \uD5A5\uD6C4 \uC8FC\uC694 \uC11C\uBE44\uC2A4\uC640\uC758
    \uC5F0\uB3D9 \uBC94\uC704\uB97C \uB2E8\uACC4\uC801\uC73C\uB85C \uD655\uB300\uD560
    \uACC4\uD68D\uC774\uB77C\uACE0 \uBC1D\uD614\uB2E4.\r\n"
