  m_text: "\uC6B0\uB9AC\uAC00 <link=\"q1_trigger\">1+1=2</link> \uB77C\uACE0 \uD558\uB294
    \uC774\uC720\uB294:\n\uC57D\uC18D: '1 \uB2E4\uC74C\uC758 \uC218'\uB97C '2'\uB77C\uACE0
    \uBD80\uB974\uAE30\uB85C \uC804 \uC138\uACC4\uAC00 \uC57D\uC18D\uD588\uAE30 \uB54C\uBB38\uC774\uACE0,\n\uB17C\uB9AC:
    \uD604\uB300 \uC218\uD559\uC758 \uAC00\uC7A5 \uAE30\uCD08\uC801\uC778 \uB17C\uB9AC
    \uCCB4\uACC4 \uC548\uC5D0\uC11C \uADF8\uAC83\uC774 \uBAA8\uC21C \uC5C6\uC774
    \uC131\uB9BD\uD558\uAE30 \uB54C\uBB38\uC785\uB2C8\uB2E4.\n\uB9C8\uCE58 \uC5B8\uC5B4\uC5D0\uC11C
    \uC0AC\uACFC\uB97C '\uC0AC\uACFC'\uB77C\uACE0 \uBD80\uB974\uAE30\uB85C \uC57D\uC18D\uD55C
